        hvacTempUseCase.setRow1RightTemp(value)
    }

    /**
     * Sets Steering wheel heat level in order off..1..2..off..
     *
     */
    fun updateSteeringWheelLevel(steeringWheelStatus: Int) {
        var updatedSteeringWheelStatus = when (steeringWheelStatus) {
            HeatSteeringWheel.HSW_TEMPERATURE_LEVEL_OFF -> HeatSteeringWheel.HSW_TEMPERATURE_LEVEL_2
            HeatSteeringWheel.HSW_TEMPERATURE_LEVEL_1 -> HeatSteeringWheel.HSW_TEMPERATURE_LEVEL_OFF
            HeatSteeringWheel.HSW_TEMPERATURE_LEVEL_2 -> HeatSteeringWheel.HSW_TEMPERATURE_LEVEL_1
            else -> {
                HeatSteeringWheel.HSW_TEMPERATURE_LEVEL_OFF
            }
        }
        logDebug("Steering Wheel Status = $updatedSteeringWheelStatus")
        hswUseCase.setSteeringWheelHeatTemprature(updatedSteeringWheelStatus)
    }

