                it?.let {
                    frontRowLeftTemperature.emit(it.temp)
                    JeaLogger.debug("frontRowLeftTemperature : ${frontRowLeftTemperature.value}")

                }
            }
        }
    }

    private fun initRecirculation() {
        coroutineScope.launch {
            hvacRecirculationUseCase.state.collect {
                logDebug("collect change in hvacRecirculationUseCase")
