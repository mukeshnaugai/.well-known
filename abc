    }

    private fun getSideMirrorHeat() {
        hvacSideMirrorHeat.sideMirrorHeatState.collect(
            coroutineScope = viewModelScope,
            dispatcher = default
        ) { withContext(context = mainDispatcher) { sideMirrorHeat = this@collect } }
