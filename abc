    private fun collectLPMState() {
        JeaLogger.debug("collect LPM State ${this@FccdTopDrawerViewModel.hashCode()}")
        lowPowerModeUseCase.lowPowerModeState.collect(
            coroutineScope = coroutineScope, dispatcher = default
        ) {
            withContext(mainDispatcher) { lowPowerModeEnabled.value = this@collect.isLPMEnable }
