    init {
        collectTemperatureUnitType()
        initMaxDefrostState()
        initFrontLeftTemp()
        initRecirculation()
        initSyncState()
        initFrontRightTemp()
        initSteeringWheelTemp()
        initFrontAutoState()
        initHvacEfficientAuto()
        initHvacRecircState()
        getClimateControlsInhibitStatus()
        initFrontElectricDefrosterState()
        initRearElectricDefrosterState()
        getSideMirrorHeat()
        infoCCFState()
        infoCCFHdmSoftBtn()
        selectedSeatTemperatureIntensityState()
        getGearStatus()
        getGloveboxState()
        checkVehicleModeTransport()
        collectValetModeState()
        initMaxAcState()
        initHvacAcState()
        collectLPMState()

        coroutineScope.launch {
            powerUseCase.frontPowerState.collect() {
                it?.let {
                    climateFrontRowPowerButtonState.emit(it.isFrontOn)
                    JeaLogger.debug("PowerAutoSyncStateHandler11 : climateFrontRowPowerButtonState:${it} ")
                }
            }
        }

        coroutineScope.launch {
            powerUseCase.rearPowerState.collect() {
                it?.let {
                    climateFrontRowPowerButtonState.emit(it.isRearOn)
                    JeaLogger.debug("PowerAutoSyncStateHandler222 : climateRearRowPowerButtonState:${it.isRearOn} ")
                }
            }
        }

