            withContext(mainDispatcher) {
                rearElectricDefrosterState = this@collect
                if (rearDefoggerState != rearElectricDefrosterState?.isRearDefoggerOn && !firstLaunch) onHeatedScreenChanged()
                firstLaunch = false
                rearDefoggerState = rearElectricDefrosterState?.isRearDefoggerOn == true
                JeaLogger.debug("initRearElectricDefrosterState: $rearDefoggerState ", "FccdTopDrawerViewModel")

