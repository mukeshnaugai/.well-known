        viewModelScope.launch(default) {
            withContext(mainDispatcher) {
                hdmSoftBtnFitment = hvacSideMirrorHeat.getInfoHDM()?.isAvailable ?: false
                logDebug("hdmSoftBtnFitment $hdmSoftBtnFitment")
            }
        }
    }

    /**
     * This method will sync seat temperature intensity state from backend
     */
    private fun selectedSeatTemperatureIntensityState() {
        climateIntensity.leftIntensity.collect(viewModelScope, default) {
            withContext(mainDispatcher) {
                if (this@collect.state == tempValue) return@withContext
                driverSeatTemperature = getSelectedSeatTemperatureIntensity(this@collect.state)
                logDebug("driver seat temperature value $driverSeatTemperature")
            }
        }

        climateIntensity.rightIntensity.collect(viewModelScope, default) {
            withContext(mainDispatcher) {
                if (this@collect.state == tempValue) return@withContext
                passengerSeatTemperature = getSelectedSeatTemperatureIntensity(this@collect.state)
                logDebug("passenger seat temperature value $passengerSeatTemperature")
            }
        }
    }

