    private fun initFrontElectricDefrosterState() {
        hvacDefoggerUseCase.frontElectricDefrosterState.collect(
            coroutineScope = viewModelScope,
            dispatcher = default
        ) {
            withContext(mainDispatcher) {
                frontElectricDefrosterState = this@collect
                if (frontDefoggerState != frontElectricDefrosterState?.isFrontDefoggerOn && !firstLaunch) onHeatedScreenChanged()
                firstLaunch = false
                frontDefoggerState = frontElectricDefrosterState?.isFrontDefoggerOn == true
                JeaLogger.debug("initFrontElectricDefrosterState: $frontDefoggerState ", "FccdTopDrawerViewModel")
            }
        }
    }

    private fun initRearElectricDefrosterState() {
        hvacDefoggerUseCase.rearElectricDefrosterState.collect(
            coroutineScope = viewModelScope,
            dispatcher = default
