    }

    fun switchSideMirrorHeat() {
        hvacSideMirrorHeat.switchSideMirrorHeat(data = if (sideMirrorHeat?.state == HeatedDoorMirrors.DEFROSTER_MODE_ON) HeatedDoorMirrors.DEFROSTER_MODE_OFF else HeatedDoorMirrors.DEFROSTER_MODE_ON)
    }

    fun setSeatTemperature(seatPosition: Int, intensityValue: Int) {
        climateIntensity.setClimateIntensity(seatPosition, intensityValue)
    }

    /**
     * @property awayModeStateHandler State handling and business logic integration for awayMode button.
     */
    val awayModeStateHandler: AwayModeStateHandler = AwayModeStateHandler(
        awayModeState = hvacClimatePreconditionUseCase,
        coroutineScope = viewModelScope
    )

    private fun onHeatedScreenChanged() {
        feedbackMessage = true
        viewModelScope.launch(default) {
            delay(4000)
            withContext(mainDispatcher) { feedbackMessage = false }
        }
    }

    private fun lastInteractionLessThanTenSeconds(): Boolean {
        val currentTime = System.currentTimeMillis()
        val timeDifference = currentTime - lastInteractionTime
        lastInteractionTime = currentTime
        return timeDifference <= TIME_OUT
    }

    /**
     *  seat temperature power switch state to toggle mapping
     */
    private fun getSelectedSeatTemperatureState(temperaturePowerState: Int): Boolean {
        return when (temperaturePowerState) {
            SEAT_CLIMATE_STATE_OFF -> false
            SEAT_CLIMATE_STATE_ON -> true
            else -> false
        }
    }

    /**
     *  seat temperature intensity level state to temperature value switcher mapping
     */
    private fun getSelectedSeatTemperatureIntensity(temperatureIntensity: Int): Float {
        return when (temperatureIntensity) {
            SEAT_CLIMATE_INTENSITY_OFF -> 0f
            SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_1 -> 1f
            SEAT_CLIMATE_INTENSITY_COOL_LEVEL_1 -> -1f
            SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_2 -> 2f
            SEAT_CLIMATE_INTENSITY_COOL_LEVEL_2 -> -2f
            SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_3 -> 3f
            SEAT_CLIMATE_INTENSITY_COOL_LEVEL_3 -> -3f
            else -> 0f
        }
    }

    /**
     *  seat temperature value switcher to intensity level state mapping
     */
    fun getSelectedSeatTemperature(temperatureIntensity: Float): Int {
        return when (temperatureIntensity) {
            0f -> SEAT_CLIMATE_INTENSITY_OFF
            1f -> SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_1
            -1f -> SEAT_CLIMATE_INTENSITY_COOL_LEVEL_1
            2f -> SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_2
            -2f -> SEAT_CLIMATE_INTENSITY_COOL_LEVEL_2
            3f -> SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_3
            -3f -> SEAT_CLIMATE_INTENSITY_COOL_LEVEL_3
            else -> SEAT_CLIMATE_INTENSITY_OFF
        }
    }

    /**
     * selected seat position and vehicle seat area id mapping
     */
    fun getSeatSelection(selectedSeatPosition: Int): Int {
        return when (selectedSeatPosition) {
            SEAT_POSITION_DRIVER -> SEAT_SELECTION_FIRST_ROW_LEFT
            SEAT_POSITION_PASSENGER -> SEAT_SELECTION_FIRST_ROW_RIGHT
            SEAT_POSITION_REAR_LEFT -> SEAT_SELECTION_SECOND_ROW_LEFT
            SEAT_POSITION_REAR_RIGHT -> SEAT_SELECTION_SECOND_ROW_RIGHT
            else -> 0
        }
    }

    /**
     *  seat temperature power switch toggle to state mapping
     */
    private fun getPowerState(powerState: Boolean): Int {
        return when (powerState) {
            false -> SEAT_CLIMATE_STATE_OFF
            true -> SEAT_CLIMATE_STATE_ON
        }
    }

    companion object {
        const val TIME_OUT = 10000
        const val TEMPERATURE_OFF_VALUE = 0f
        const val TEMPERATURE_MAX_VALUE = 3f
        const val TEMPERATURE_MIN_VALUE_ZONE_DUAL = -3f
        const val TEMPERATURE_MIN_VALUE_ZONE_SINGLE = 0f
        const val GLOVEBOX_ON = 1
        const val GLOVEBOX_OFF = 0
        const val GLOVEBOX_TOAST_TIMEOUT = 8000L
        const val TIMEOUT_ONE_SECOND = 1000L
        const val TIMEOUT_600_MIL_SECOND = 600L
        const val TIMEOUT_400_MIL_SECOND = 400
        const val ANIMATION_TIMEOUT_300_MIL_SECOND = 300
        const val TIMEOUT_300_MIL_SECOND = 300L

    }
}
