                color = JeaCommonTheme.colorPalette.Light_Text_Default,
                style = JeaCommonTheme.typography.largeTitle,
                textAlign = TextAlign.Center
            )

        }
    }

    private @Composable
    fun RightColumnGroup(rccdTopDrawerViewModel: RccdTopDrawerViewModel, isTemperatureCelsius: Boolean, climateRearRowPowerState: Boolean,
                         showContent: Boolean, showBubble: Boolean,
                         onJeaACTempDragStart: () -> Unit,
                         onJeaACTempDragEnd: () -> Unit,
                         onTemperatureChange: (Float) -> Unit,
                         tempValue: Float,
                         isRightOpen: Boolean,
                         activeDragSide: String?) {
        val rightClimateCurrentValue =
            rccdTopDrawerViewModel.rearRowRightTemperature.collectAsState()
        val decrementPassengerButtonState = remember { mutableStateOf(com.jlr.ui.State(enabled = true)) }
        val incrementPassengerButtonState = remember { mutableStateOf(com.jlr.ui.State(enabled = true)) }
        val coroutineScope = rememberCoroutineScope()
        val bubbleHeight = 50.dp
        val bubbleWidth = 60.dp
        val bubbleTargetHeight = 360.dp
        val isTemperatureCelsius: Boolean = rccdTopDrawerViewModel.temperatureStateHandler.isTemperatureCelcius.collectAsState().value

        Column(
            modifier = Modifier
                .padding(top = dimensionResource(id = R.dimen.rccd_top_drawer_column_top_padding), start = dimensionResource(id = R.dimen.rccd_top_drawer_column_start_padding))
        ) {

            val decrementButtonStateRearRight = if (rightClimateCurrentValue.value == TEMPERATURE_MIN_VALUE) {
                com.jlr.ui.State(enabled = false)
            } else {
                com.jlr.ui.State(enabled = true)
            }
            val incrementButtonStateRearRight = if (rightClimateCurrentValue.value == TemperatureStateHandler.TEMPERATURE_MAX_VALUE) {
                com.jlr.ui.State(enabled = false)
            } else {
                com.jlr.ui.State(enabled = true)
            }

            if (showBubble) {
                if (isRightOpen) {
                    var expanded by remember { mutableStateOf(false) }
                    var visible by remember { mutableStateOf(true) }

                    // Animate height from bubble to slider and back
                    val animatedHeight by animateDpAsState(
                        targetValue = if (expanded) bubbleTargetHeight else bubbleHeight,
                        animationSpec = tween(durationMillis = BUBBLE_ANIMATION_DURATION, easing = FastOutSlowInEasing)
                    )

                    // Animate alpha for fade in/out
                    val animatedAlpha by animateFloatAsState(
                        targetValue = if (visible) COERCE_MAX else COERCE_MIN,
                        animationSpec = tween(durationMillis = 400)
                    )

                    val bubbleWidth = bubbleWidth

                    Box(
                        modifier = Modifier.fillMaxSize(),
                        contentAlignment = Alignment.Center
                    ) {
                        Box(
                            modifier = Modifier
                                .width(bubbleWidth)
                                .height(animatedHeight)
                                .offset(y = dimensionResource(R.dimen.fccd_slider_yoffset))
                                .alpha(animatedAlpha)
                                .clip(RoundedCornerShape(dimensionResource(R.dimen.fccd_slider_corner_radius)))
                        ) {
                            Image(
                                painter = painterResource(id = R.drawable.jea_climate_slider),
                                contentDescription = stringResource(R.string.jea_content_description_fccd_drawer),
                                contentScale = ContentScale.FillBounds,
                                modifier = Modifier.fillMaxSize()
                            )
                        }
                    }

                    // Start expansion when bubble appears
                    LaunchedEffect(Unit) {
                        expanded = true
                    }

                    // Reverse when drag ends
                    LaunchedEffect(showContent) {
                        if (showContent) {
                            expanded = false // Shrink back
                            delay(600)       // Wait for shrink animation
                            visible = false  // Fade out
                        }
                    }
                }
            }

            Box {
                val dragAlpha = calculateDragAlpha(showContent, activeDragSide, isLeftColumn = false, isRightColumn = true)
                val dragOffset by animateDpAsState(
                    if (showContent) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset) else dimensionResource(R.dimen.fccd_drawer_animation_target_offset), tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(enabled = showBubble && isRightOpen)
                ) {
                    JeaAcTemp(
                        jeaAcTempsConfig = JeaTheme.configProvider.jeaAcTempsConfig.copy(
                            minValue = if (isTemperatureCelsius) TEMPERATURE_MIN_VALUE else TEMPERATURE_MIN_VALUE_FAHRENHEIT,
                            maxValue = if (isTemperatureCelsius) TemperatureStateHandler.TEMPERATURE_MAX_VALUE else TEMPERATURE_MAX_VALUE_FAHRENHEIT,
                            stepValue = TemperatureStateHandler.TEMPERATURE_STEP_VALUE,
                            minValueTextString = (if (isTemperatureCelsius) TEMPERATURE_MIN_VALUE_PASSENGER else TEMPERATURE_MIN_VALUE_FAHRENHEIT_PASSENGER.toInt()).toString(),
                            maxValueTextString = (if (isTemperatureCelsius) TEMPERATURE_MAX_VALUE_PASSENGER else TEMPERATURE_MAX_VALUE_FAHRENHEIT_PASSENGER.toInt()).toString(),
                            offTextString = if (climateRearRowPowerState) null else stringResource(R.string.jea_climate_option_off),
                        ),
                        jeaAcTempState = JeaAcTempState(
                            shouldShowFloat = isTemperatureCelsius,
                            decrementButtonState = decrementButtonStateRearRight,
                            incrementButtonState = incrementButtonStateRearRight,
                            onDecrementBtnClick = { value: Float, valueType: ValueType ->
                                JeaLogger.info(message = "will decrement rear right temp, current temp is ${rightClimateCurrentValue.value}", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                val nextValue = rightClimateCurrentValue.value - TemperatureStateHandler.TEMPERATURE_STEP_VALUE
                                if (nextValue >= TemperatureStateHandler.TEMPERATURE_MIN_VALUE_PASSENGER) {
                                    rccdTopDrawerViewModel.setRearRightSeatTemperature(nextValue)
                                }
                            },
                            buttonClick = {
                                rccdTopDrawerViewModel.isDrawerSlidable = false

                                if (!topDrawerInteractor.isDrawerHidden.value) {
                                    topDrawerInteractor.setHideDrawerFlag(true)
                                }
                                if (!launcherInteractor.isTempPageScreen.value) {
                                    launcherInteractor.setShouldOpenTempScreen(true)
                                }
                                rccdTopDrawerViewModel.isDrawerSlidable = true

                            },
                            onIncrementBtnClick = { value: Float, valueType: ValueType ->
                                JeaLogger.info(message = "will increment rear right temp, current temp is ${rightClimateCurrentValue.value}", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                val nextValue = rightClimateCurrentValue.value + TemperatureStateHandler.TEMPERATURE_STEP_VALUE
                                if (nextValue <= TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER) {
                                    rccdTopDrawerViewModel.setRearRightSeatTemperature(nextValue)
                                }
                            },
                            darkMode = false,
                            valueBottomTextBoxState = if (isTemperatureCelsius) rightClimateCurrentValue.value else {
                                val currentCelsius = rightClimateCurrentValue.value
                                when {
                                    currentCelsius <= TEMPERATURE_MIN_VALUE -> TEMPERATURE_MIN_VALUE_FAHRENHEIT
                                    currentCelsius >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE -> TEMPERATURE_MAX_VALUE_FAHRENHEIT
                                    else -> {
                                        celsiusToFahrenheit(currentCelsius)
                                    }
                                }
                            },
                            dragEventAllowed = true,
                            onDragStart =
                                {
                                    rccdTopDrawerViewModel.isDriverTemperatureSelected = false
                                    rccdTopDrawerViewModel.isDrawerSlidable = false
                                    onJeaACTempDragStart()
                                },

                            onDragEnd = {
                                val setTempVal = when {
                                    tempValue >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER -> TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER
                                    tempValue <= TEMPERATURE_MIN_VALUE_PASSENGER -> TEMPERATURE_MIN_VALUE_PASSENGER
                                    else -> tempValue
                                }
                                rccdTopDrawerViewModel.setRearRightSeatTemperature(setTempVal)
                                onJeaACTempDragEnd()
                                JeaLogger.info("TempProgressVal= $tempValue", tag = "FCCDDragVal")
                                rccdTopDrawerViewModel.isDrawerSlidable = true

                            },
                            onDragInProgress = { progressVal ->
                                rccdTopDrawerViewModel.isDrawerSlidable = false
                                onTemperatureChange(rightClimateCurrentValue.value + (progressVal.toFloat() / 2))
                                JeaLogger.info("DragVal= $progressVal", tag = "FCCDDragVal")
                            },
                            unitTextBoxText = TemperatureStateHandler.TEMPERATURE_UNIT
                        )
                    )
                }
            }

            Spacer(modifier = Modifier.height(dimensionResource(id = R.dimen.rccd_top_drawer_right_column_spacer_height)))

            Box {
                val dragAlpha = calculateDragAlpha(showContent, activeDragSide, isLeftColumn = false, isRightColumn = true)
                val dragOffset by animateDpAsState(
                    if (showContent) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset) else dimensionResource(R.dimen.fccd_drawer_animation_target_offset), tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(enabled = showBubble && isRightOpen)
                ) {
            JeaSeatTemp(
                JeaTheme.configProvider.jeaSeatTempConfig.copy(
                    minValue = rccdTopDrawerViewModel.minIntensityListValue,
                    maxValue = TEMPERATURE_MAX_VALUE
                ),
                JeaSeatTempState(
                    decrementButtonState = com.jlr.ui.State(
                        enabled = !rccdTopDrawerViewModel.decrementPassengerButtonStateDisabled
                    ),
                    incrementButtonState = com.jlr.ui.State(
                        enabled = !rccdTopDrawerViewModel.incrementPassengerButtonStateDisabled
                    ),
                    onDecrementBtnClick = { value: Float, valueType: ValueType ->
                        when (valueType) {
                            ValueType.NUMBER,
                            ValueType.NUMBER_WITH_MIN_MAX_TEXT
                                -> {
                                rccdTopDrawerViewModel.setSeatTemperature(
                                    rccdTopDrawerViewModel.getSeatSelection(SeatPosition.SEAT_POSITION_REAR_RIGHT),
                                    rccdTopDrawerViewModel.getSelectedSeatTemperature(value)
                                )
                            }

                            ValueType.CUSTOM_TEXT -> {}
                            ValueType.IMAGE -> {}
                        }
                    },
                    onIncrementBtnClick = { value: Float, valueType: ValueType ->
                        when (valueType) {
                            ValueType.NUMBER,
                            ValueType.NUMBER_WITH_MIN_MAX_TEXT
                                -> {
                                rccdTopDrawerViewModel.setSeatTemperature(
                                    rccdTopDrawerViewModel.getSeatSelection(SeatPosition.SEAT_POSITION_REAR_RIGHT),
                                    rccdTopDrawerViewModel.getSelectedSeatTemperature(value)
                                )
                            }

                            ValueType.CUSTOM_TEXT -> {}
                            ValueType.IMAGE -> {}
                        }
                    },
                    darkMode = false,
                    inverse = true,
                    valueBottomTextBoxState = rccdTopDrawerViewModel.rearRightSeatTemperatures,
                    valueBottomTextBoxPosition = 0,
                    buttonClick = {
                        if (!topDrawerInteractor.isDrawerHidden.value) {
                            topDrawerInteractor.setHideDrawerFlag(true)
                        }
                        if (!launcherInteractor.isSeatsPageScreen.value) {
                            launcherInteractor.setNavigationStatus(true)
                            launcherInteractor.setShouldOpenHomeListScreen(false)
                            launcherInteractor.setShouldOpenSeatsScreen(true)
                        }
                        launcherInteractor.setShouldOpenSeatsSelectedScreen(SEAT_POSITION_REAR_RIGHT)
                    }
                )
            )
                }
            }
        }
    }

    @Composable
    private fun MiddleColumnGroup(rccdTopDrawerViewModel: RccdTopDrawerViewModel, efficientAutoMode: EfficientAutoMode?,showContent: Boolean,
                                  showBubble: Boolean,
                                  tempValue: Float,
                                  activeDragSide: String?,
                                  climateRearRowPowerState: Boolean) {
        Column(
            modifier = Modifier
                .padding(start = dimensionResource(id = R.dimen.rccd_top_drawer_column_start_padding_26),
                    top = dimensionResource(id = R.dimen.aad_handsfree_ui_top) ),
            verticalArrangement = Arrangement.SpaceBetween,
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            val autoButtonState: State<Boolean> = rccdTopDrawerViewModel.frontAutoButtonState.collectAsState()
            val syncButtonState: State<Boolean> = rccdTopDrawerViewModel.syncButtonState.collectAsState()
            val rearLeftAcDistributionState = rccdTopDrawerViewModel.rearLeftAcDistributionState.collectAsState()
            val baseW = 120.dp
            val baseH = 60.dp
            val pulseW = 160.dp
            val pulseH = 80.dp
            val shrinkDurationMs = BUBBLE_ANIMATION_DURATION
            val textFadeDurationMs = ANIMATION_TIMEOUT_300_MIL_SECOND
            val bubbleFadeDurationMs = TIMEOUT_400_MIL_SECOND
            var localBubbleVisible by remember { mutableStateOf(false) }
            var middleRevealGate by remember { mutableStateOf(showContent) }
            var inEndSequence by remember { mutableStateOf(false) }
            var targetW by remember { mutableStateOf(baseW) }
            var targetH by remember { mutableStateOf(baseH) }
            var textAlphaTarget by remember { mutableStateOf(COERCE_MAX) }
            var bubbleAlphaTarget by remember { mutableStateOf(COERCE_MAX) }
            val isDragging = showBubble && !showContent
            val animatedWidth by animateDpAsState(
                targetValue = targetW,
                animationSpec = tween(
                    durationMillis = if (inEndSequence) shrinkDurationMs else ANIMATION_TIMEOUT_300_MIL_SECOND,
                    easing = FastOutSlowInEasing
                )
            )
            val animatedHeight by animateDpAsState(
                targetValue = targetH,
                animationSpec = tween(
                    durationMillis = if (inEndSequence) shrinkDurationMs else ANIMATION_TIMEOUT_300_MIL_SECOND,
                    easing = FastOutSlowInEasing
                )
            )

            val textAlpha by animateFloatAsState(
                targetValue = textAlphaTarget,
                animationSpec = tween(durationMillis = textFadeDurationMs)
            )
            val bubbleAlpha by animateFloatAsState(
                targetValue = bubbleAlphaTarget,
                animationSpec = tween(durationMillis = bubbleFadeDurationMs)
            )

            LaunchedEffect(isDragging, showBubble) {
                if (isDragging) {
                    localBubbleVisible = true
                    middleRevealGate = false
                    inEndSequence = false
                    bubbleAlphaTarget = COERCE_MAX
                    textAlphaTarget = COERCE_MAX
                    targetW = pulseW; targetH = pulseH
                    delay(ANIMATION_TIMEOUT_300_MIL_SECOND.toLong())
                    targetW = baseW; targetH = baseH
                }
            }

            LaunchedEffect(showContent) {
                if (showContent && localBubbleVisible) {
                    inEndSequence = true
                    middleRevealGate = false
                    targetW = baseW; targetH = baseH
                    textAlphaTarget = COERCE_MIN
                    delay(textFadeDurationMs.toLong())
                    bubbleAlphaTarget = COERCE_MIN
                    delay(bubbleFadeDurationMs.toLong())
                    inEndSequence = false
                    localBubbleVisible = false
                    bubbleAlphaTarget = COERCE_MAX
                    textAlphaTarget = COERCE_MAX
                    middleRevealGate = true
                }
            }

             if (showBubble || localBubbleVisible) {
                 Box(
                     modifier = Modifier.wrapContentSize(),
                     contentAlignment = Alignment.TopCenter
                 ) {
                     Box(
                         modifier = Modifier
                             .offset(y = dimensionResource(R.dimen.fccd_bubble_slider_offset))
                             .width(animatedWidth)
                             .height(animatedHeight)
                             .graphicsLayer { alpha = bubbleAlpha }
                             .shadow(
                                 dimensionResource(R.dimen.fccd_bubble_shadow_elevation),
                                 spotColor = colorResource(R.color.fccd_drawer_bubble_spot_color),
                                 ambientColor = colorResource(R.color.fccd_drawer_bubble_spot_color),
                                 shape = RoundedCornerShape(animatedHeight / 2)
                             )
                             .background(
                                 color = JeaCommonTheme.colorPalette.Light_Surface_Fill_Climate_Airflow_Button,
                                 shape = RoundedCornerShape(animatedHeight / 2)
                             ),
                         contentAlignment = Alignment.Center
                     ) {
                         androidx.compose.material.Text(
                             text = if (rccdTopDrawerViewModel.isDriverTemperatureSelected) {

                                 if (rccdTopDrawerViewModel.isTemperatureCelcius == true) {
                                     when {
                                         tempValue >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE -> stringResource(id = R.string.jea_climate_option_temp_hi)
                                         tempValue <= TEMPERATURE_MIN_VALUE -> stringResource(id = R.string.jea_climate_option_temp_lo)
                                         else -> "${tempValue}$TEMPERATURE_UNIT"
                                     }
                                 } else {
                                     when {
                                         tempValue >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE -> stringResource(id = R.string.jea_climate_option_temp_hi)
                                         tempValue <= TEMPERATURE_MIN_VALUE -> stringResource(id = R.string.jea_climate_option_temp_lo)
                                         else -> {
                                             val f = celsiusToFahrenheit(tempValue)
                                             "${f.toInt()}$TEMPERATURE_UNIT"
                                         }
                                     }
                                 }
                             } else {
                                 if (rccdTopDrawerViewModel.isTemperatureCelcius == true) {
                                     when {
                                         tempValue >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER -> TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER.toString()
                                         tempValue <= TEMPERATURE_MIN_VALUE_PASSENGER -> TEMPERATURE_MIN_VALUE_PASSENGER.toString()
                                         else -> "${tempValue}$TEMPERATURE_UNIT"
                                     }
                                 } else {
                                     when {
                                         tempValue >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER -> TemperatureStateHandler.TEMPERATURE_MAX_VALUE_FAHRENHEIT_PASSENGER.toString()
                                         tempValue <= TEMPERATURE_MIN_VALUE_PASSENGER -> TEMPERATURE_MIN_VALUE_FAHRENHEIT_PASSENGER.toString()
                                         else -> {
                                             val f = celsiusToFahrenheit(tempValue)
                                             "${f.toInt()}$TEMPERATURE_UNIT"
                                         }
                                     }
                                 }
                             },
                             color = JeaCommonTheme.colorPalette.Light_Text_Default,
                             style = JeaCommonTheme.typography.largeSentenceOrTitle37pt,
                             modifier = Modifier.graphicsLayer { alpha = textAlpha }
                         )
                     }
                 }
             }

            Box {
                val dragAlpha = calculateDragAlpha(middleRevealGate, activeDragSide, isLeftColumn = false, isRightColumn = true)
                val dragOffset by animateDpAsState(
                    if (middleRevealGate) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset)
                    else dimensionResource(R.dimen.fccd_drawer_animation_target_offset),
                    tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(false)
                ) {
                    JeaClimateBtn(
                        state = JeaClimateBtnState(
                            variant = JeaClimateBtnVariant.BtnWithIcon(
                                iconRes = if (syncButtonState.value)
                                    R.drawable.jea_sync_selected
                                else
                                    R.drawable.jea_sync_selectable,
                                contentDescription = stringResource(id = R.string.jea_sync_text)
                            ),
                            buttonState =
                                when {
                                    syncButtonState.value ->
                                        ClimateBtnStates.SELECTED
                                    else ->
                                        ClimateBtnStates.SELECTABLE
                                },

                            onClick = { rccdTopDrawerViewModel.toggleSyncButtonState() },
                            isRemoveBG = !syncButtonState.value,
                            isDeferredClickAllowed = true
                        )
                    )
                }
            }

            Spacer(modifier = Modifier.height(dimensionResource(R.dimen.rccd_topdrawer_cloumn_spacer_height_50)))

            Box {

                val dragAlpha = calculateDragAlpha(middleRevealGate, activeDragSide, isLeftColumn = false, isRightColumn = true)
                val dragOffset by animateDpAsState(
                    if (middleRevealGate) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset)
                    else dimensionResource(R.dimen.fccd_drawer_animation_target_offset),
                    tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(false)
                ) {
                    JeaClimateBtn(
                        state = JeaClimateBtnState(
                            variant =
                                JeaClimateBtnVariant.BtnWithTextAndIcon(
                                    text = stringResource(id = R.string.jea_auto_text).uppercase(),
                                    iconRes = R.drawable.jea_efficient_heating,
                                    contentDescription = stringResource(id = R.string.jea_auto_text)
                                ),
                            buttonState = if (autoButtonState.value) ClimateBtnStates.SELECTED else ClimateBtnStates.SELECTABLE,
                            onClick = {
                                rccdTopDrawerViewModel.toggleFrontAutoButtonState()
                            }
                        ),
                    )
                }
            }

            Spacer(modifier = Modifier.height(dimensionResource(id = R.dimen.rccd_topdrawer_cloumn_spacer_height_50)))

            rearLeftAcDistributionState.value.isDistributionModeAuto
            Box {
                val dragAlpha = calculateDragAlpha(middleRevealGate, activeDragSide, isLeftColumn = false, isRightColumn = true)
                val dragOffset by animateDpAsState(
                    if (middleRevealGate) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset)
                    else dimensionResource(R.dimen.fccd_drawer_animation_target_offset),
                    tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(false)
                ) {
                    JeaCircularButton(
                        JeaCircularButtonState(
                            iconResId = R.drawable.jea_climate_ac_distribution_face,
                            mode = if (rearLeftAcDistributionState.value.faceEnabled)
                                com.jlr.ui.State(selected = true)
                            else
                                com.jlr.ui.State(),
                            showBg = false, onClick = {
                                rccdTopDrawerViewModel.setFaceVentSwitch()
                            }
                        ),
                        jeaCircularButtonConfig = JeaTheme.configProvider.jeaCircularButtonConfig.copy(jeaCircularButtonStyle = JeaCircularButtonStyle.LIGHT, padding = Padding(top = dimensionResource(id = R.dimen.rccd_topdrawer_empty_padding), end = dimensionResource(id = R.dimen.rccd_topdrawer_empty_padding), bottom = dimensionResource(id = R.dimen.rccd_topdrawer_empty_padding), start = dimensionResource(id = R.dimen.rccd_topdrawer_empty_padding)))
                    )
                }
            }

            Spacer(modifier = Modifier.height(dimensionResource(id = R.dimen.rccd_topdrawer_cloumn_spacer_height_50)))

            Box {
                val dragAlpha = calculateDragAlpha(middleRevealGate, activeDragSide, isLeftColumn = false, isRightColumn = true)
                val dragOffset by animateDpAsState(
                    if (middleRevealGate) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset)
                    else dimensionResource(R.dimen.fccd_drawer_animation_target_offset),
                    tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(false)
                ) {
                    JeaCircularButton(
                        JeaCircularButtonState(
                            iconResId = R.drawable.jea_climate_ac_distribution_feet,
                            mode = if (rearLeftAcDistributionState.value.footEnabled)
                                com.jlr.ui.State(selected = true)
                            else
                                com.jlr.ui.State(),
                            showBg = false, onClick = {
                                rccdTopDrawerViewModel.setFootVentSwitch()
                            }
                        ),
                        jeaCircularButtonConfig = JeaTheme.configProvider.jeaCircularButtonConfig.copy(jeaCircularButtonStyle = JeaCircularButtonStyle.LIGHT, padding = Padding(top = dimensionResource(id = R.dimen.rccd_topdrawer_empty_padding), end = dimensionResource(id = R.dimen.rccd_topdrawer_empty_padding), bottom = dimensionResource(id = R.dimen.rccd_topdrawer_empty_padding), start = dimensionResource(id = R.dimen.rccd_topdrawer_empty_padding)))
                    )
                }
            }
        }
    }

    private @Composable
    fun LeftColumnGroup(rccdTopDrawerViewModel: RccdTopDrawerViewModel,
                        showContent: Boolean,
                        showBubble: Boolean,
                        onJeaACTempDragStart: () -> Unit,
                        onJeaACTempDragEnd: () -> Unit,
                        onTemperatureChange: (Float) -> Unit,
                        isTemperatureCelsius: Boolean,
                        tempValue: Float,
                        isLeftOpen: Boolean,
                        activeDragSide: String?,
                        climateRearRowPowerState: Boolean) {
        val leftClimateCurrentValue = rccdTopDrawerViewModel.rearRowLeftTemperature.collectAsState()
        val bubbleHeight = dimensionResource(R.dimen.fccd_top_drawer_inflater_bubble_height)
        val bubbleWidth = dimensionResource(R.dimen.fccd_top_drawer_inflater_bubble_width)
        val bubbleTargetHeight = dimensionResource(R.dimen.fccd_top_drawer_inflater_bubble_trgt_height)

        Column(
            modifier = Modifier
                .padding(top = dimensionResource(id = R.dimen.rccd_top_drawer_column_top_padding), start = dimensionResource(id = R.dimen.rccd_top_drawer_column_start_padding_10))
        ) {
            val decrementButtonStateRearLeft = if (leftClimateCurrentValue.value == TEMPERATURE_MIN_VALUE) {
                com.jlr.ui.State(enabled = false)
            } else {
                com.jlr.ui.State(enabled = true)
            }
            val incrementButtonStateRearLeft = if (leftClimateCurrentValue.value == TemperatureStateHandler.TEMPERATURE_MAX_VALUE) {
                com.jlr.ui.State(enabled = false)
            } else {
                com.jlr.ui.State(enabled = true)
            }

             if (showBubble) {
                 if (isLeftOpen) {
                     var expanded by remember { mutableStateOf(false) }
                     var visible by remember { mutableStateOf(true) }

                     // Animate height from bubble to slider and back
                     val animatedHeight by animateDpAsState(
                         targetValue = if (expanded) bubbleTargetHeight else bubbleHeight,
                         animationSpec = tween(durationMillis = BUBBLE_ANIMATION_DURATION, easing = FastOutSlowInEasing)
                     )

                     // Animate alpha for fade in/out
                     val animatedAlpha by animateFloatAsState(
                         targetValue = if (visible) COERCE_MAX else COERCE_MIN,
                         animationSpec = tween(durationMillis = FADE_IN_ANIMATION_DURATION)
                     )

                     val animatedScale by animateFloatAsState(
                         targetValue = if (expanded) 1f else bubbleHeight / bubbleTargetHeight,
                         animationSpec = tween(BUBBLE_ANIMATION_DURATION, easing = FastOutSlowInEasing)
                     )

                     Box(
                         modifier = Modifier
                             .wrapContentSize()
                             .padding(start = 30.dp),
                         contentAlignment = Alignment.CenterStart
                     ) {
                         Image(
                             painter = painterResource(id = R.drawable.jea_climate_slider),
                             contentDescription = stringResource(
                                 R.string.jea_content_description_fccd_drawer
                             ),
                             contentScale = ContentScale.FillBounds,
                             modifier = Modifier
                                 .width(bubbleWidth)
                                 .height(bubbleTargetHeight)
                                 .graphicsLayer {
                                     scaleY = animatedScale
                                     transformOrigin =
                                         TransformOrigin(0.5f, 0.5f) // center expand
                                     alpha = animatedAlpha
                                 }
                                 .clip(
                                     RoundedCornerShape(
                                         dimensionResource(R.dimen.fccd_slider_corner_radius)
                                     )
                                 )
                         )
                     }

                     // Start expansion when bubble appears
                     LaunchedEffect(Unit) {
                         expanded = true
                     }

                     // Reverse when drag ends
                     LaunchedEffect(showContent) {
                         if (showContent) {
                             expanded = false // Shrink back
                             delay(TIMEOUT_600_MIL_SECOND)       // Wait for shrink animation
                             visible = false  // Fade out
                         }
                     }
                 }

             }

            Box {
                val dragAlpha = calculateDragAlpha(showContent, activeDragSide, isLeftColumn = true, isRightColumn = false)
                val dragOffset by animateDpAsState(
                    if (showContent) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset) else dimensionResource(R.dimen.fccd_drawer_animation_target_offset), tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(enabled = showBubble && isLeftOpen)
                ) {
                    JeaAcTemp(
                        jeaAcTempsConfig = JeaTheme.configProvider.jeaAcTempsConfig.copy(
                            minValue = if (isTemperatureCelsius) TEMPERATURE_MIN_VALUE else TEMPERATURE_MIN_VALUE_FAHRENHEIT,
                            maxValue = if (isTemperatureCelsius) TemperatureStateHandler.TEMPERATURE_MAX_VALUE else TEMPERATURE_MAX_VALUE_FAHRENHEIT,
                            minValueTextString = (if (isTemperatureCelsius) TEMPERATURE_MIN_VALUE_PASSENGER else TEMPERATURE_MIN_VALUE_FAHRENHEIT_PASSENGER.toInt()).toString(),
                            maxValueTextString = (if (isTemperatureCelsius) TEMPERATURE_MAX_VALUE_PASSENGER else TEMPERATURE_MAX_VALUE_FAHRENHEIT_PASSENGER.toInt()).toString(),
                            offTextString = if (climateRearRowPowerState) null else stringResource(R.string.jea_climate_option_off),
                            stepValue = TemperatureStateHandler.TEMPERATURE_STEP_VALUE,
                        ),
                        jeaAcTempState = JeaAcTempState(
                            shouldShowFloat = isTemperatureCelsius,
                            decrementButtonState = decrementButtonStateRearLeft,
                            incrementButtonState = incrementButtonStateRearLeft,
                            onDecrementBtnClick = { value: Float, valueType: ValueType ->
                                rccdTopDrawerViewModel.isDrawerSlidable = false
                              //  rccdTopDrawerViewModel.isDriverTemperatureSelected = true
                                JeaLogger.info(message = "will decrement rear left temp, current temp is ${leftClimateCurrentValue.value}", module = "systembar", feature = "rccddrawer", fileName = "TopDrawerInflater")
                                val nextValue = leftClimateCurrentValue.value - TemperatureStateHandler.TEMPERATURE_STEP_VALUE
                                if (nextValue >= TemperatureStateHandler.TEMPERATURE_MIN_VALUE_PASSENGER) {
                                    rccdTopDrawerViewModel.setRearLeftSeatTemperature(nextValue)
                                }
                                rccdTopDrawerViewModel.isDrawerSlidable = true
                            },
                            buttonClick = {
                                rccdTopDrawerViewModel.isDrawerSlidable = false
                              //  rccdTopDrawerViewModel.isDriverTemperatureSelected = true
                                if (!topDrawerInteractor.isDrawerHidden.value) {
                                    topDrawerInteractor.setHideDrawerFlag(true)
                                }
                                if (!launcherInteractor.isTempPageScreen.value) {
                                    launcherInteractor.setShouldOpenTempScreen(true)
                                }
                                rccdTopDrawerViewModel.isDrawerSlidable = true
                            },
                            onIncrementBtnClick = { value: Float, valueType: ValueType ->
                                rccdTopDrawerViewModel.isDrawerSlidable = false
                              //  rccdTopDrawerViewModel.isDriverTemperatureSelected = true
                                JeaLogger.info(message = "will increment rear left temp, current temp is ${leftClimateCurrentValue.value}", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                val nextValue = leftClimateCurrentValue.value + TemperatureStateHandler.TEMPERATURE_STEP_VALUE
                                if (nextValue <= TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER) {
                                    rccdTopDrawerViewModel.setRearLeftSeatTemperature(nextValue)
                                }
                                rccdTopDrawerViewModel.isDrawerSlidable = true
                            },
                            darkMode = false,
                            valueBottomTextBoxState = if (isTemperatureCelsius) leftClimateCurrentValue.value else {
                                val currentCelsius = leftClimateCurrentValue.value
                                when {
                                    currentCelsius <= TEMPERATURE_MIN_VALUE -> TEMPERATURE_MIN_VALUE_FAHRENHEIT
                                    currentCelsius >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE -> TEMPERATURE_MAX_VALUE_FAHRENHEIT
                                    else -> {
                                        celsiusToFahrenheit(currentCelsius)
                                    }
                                }
                            },
                            dragEventAllowed = true,
                            onDragStart =
                                {
                                   // rccdTopDrawerViewModel.isDriverTemperatureSelected = true
                                    JeaLogger.info("Left On DragStart TempProgressVal= $tempValue", tag = "RCCDTopDrawerInflater")
                                    rccdTopDrawerViewModel.isDrawerSlidable = false
                                    onJeaACTempDragStart() // triggers fade-out in parent
                                },

                            onDragEnd = {
                                val setTempVal = when {
                                    tempValue >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE -> TemperatureStateHandler.TEMPERATURE_MAX_VALUE
                                    tempValue <= TEMPERATURE_MIN_VALUE -> TEMPERATURE_MIN_VALUE
                                    else -> tempValue
                                }
                                rccdTopDrawerViewModel.setRearLeftSeatTemperature(setTempVal)
                                onJeaACTempDragEnd()
                                JeaLogger.info("Left OnDragEnd TempProgressVal= $tempValue", tag = "RCCDTopDrawerInflater")
                                rccdTopDrawerViewModel.isDrawerSlidable = true

                            },

                            onDragInProgress = { progressVal ->
                                rccdTopDrawerViewModel.isDrawerSlidable = false
                                onTemperatureChange(leftClimateCurrentValue.value + (progressVal.toFloat() / 2))
                                JeaLogger.info("Left OnDragInProgress DragVal= $progressVal", tag = "RCCDTopDrawerInflater")
                            },
                            unitTextBoxText = TemperatureStateHandler.TEMPERATURE_UNIT,
                        )
                    )
                }
            }

            Spacer(modifier = Modifier.height(dimensionResource(id = R.dimen.rccd_top_drawer_right_column_spacer_height)))

            Box {
                val dragAlpha = calculateDragAlpha(showContent, activeDragSide, isLeftColumn = true, isRightColumn = false)
                val dragOffset by animateDpAsState(
                    if (showContent) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset) else dimensionResource(R.dimen.fccd_drawer_animation_target_offset), tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(false)
                ) {
                    JeaSeatTemp(
                JeaTheme.configProvider.jeaSeatTempConfig.copy(
                    minValue = rccdTopDrawerViewModel.minIntensityListValue,
                    maxValue = TEMPERATURE_MAX_VALUE
                ),
                JeaSeatTempState(
                    decrementButtonState = com.jlr.ui.State(
                        enabled = !rccdTopDrawerViewModel.decrementDriverButtonStateDisabled
                    ),
                    incrementButtonState = com.jlr.ui.State(
                        enabled = !rccdTopDrawerViewModel.incrementDriverButtonStateDisabled
                    ),
                    onDecrementBtnClick = { value: Float, valueType: ValueType ->
                        when (valueType) {
                            ValueType.NUMBER,
                            ValueType.NUMBER_WITH_MIN_MAX_TEXT
                                -> {
                                rccdTopDrawerViewModel.setSeatTemperature(
                                    rccdTopDrawerViewModel.getSeatSelection(SeatPosition.SEAT_POSITION_REAR_LEFT),
                                    rccdTopDrawerViewModel.getSelectedSeatTemperature(value)
                                )
                            }

                            ValueType.CUSTOM_TEXT -> {}
                            ValueType.IMAGE -> {}
                        }
                    },
                    onIncrementBtnClick = { value: Float, valueType: ValueType ->
                        when (valueType) {
                            ValueType.NUMBER,
                            ValueType.NUMBER_WITH_MIN_MAX_TEXT
                                -> {
                                rccdTopDrawerViewModel.setSeatTemperature(
                                    rccdTopDrawerViewModel.getSeatSelection(SeatPosition.SEAT_POSITION_REAR_LEFT),
                                    rccdTopDrawerViewModel.getSelectedSeatTemperature(value)
                                )
                            }

                            ValueType.CUSTOM_TEXT -> {}
                            ValueType.IMAGE -> {}
                        }
                    },
                    darkMode = false,
                    inverse = false,
                    valueBottomTextBoxState = rccdTopDrawerViewModel.rearLeftSeatTemperatures,
                    valueBottomTextBoxPosition = 0,
                    buttonClick = {
                        if (!topDrawerInteractor.isDrawerHidden.value) {
                            topDrawerInteractor.setHideDrawerFlag(true)
                        }
                        if (!launcherInteractor.isSeatsPageScreen.value) {
                            launcherInteractor.setNavigationStatus(true)
                            launcherInteractor.setShouldOpenHomeListScreen(false)
                            launcherInteractor.setShouldOpenSeatsScreen(true)
                        }
                        launcherInteractor.setShouldOpenSeatsSelectedScreen(SEAT_POSITION_REAR_LEFT)
                    }
                )
            )
                }
            }
        }
    }

    @Composable
    fun calculateDragAlpha(
        showContent: Boolean,
        activeDragSide: String?,
        isLeftColumn: Boolean,
        isRightColumn: Boolean
    ): Float {
        if (activeDragSide == "left" && isRightColumn) return COERCE_MIN
        if (activeDragSide == "right" && isLeftColumn) return COERCE_MIN

        val revealReady = showContent && activeDragSide == null

        var gateOpen by remember { mutableStateOf(false) }

        LaunchedEffect(revealReady) {
            gateOpen = false

            if (revealReady) {
                androidx.compose.runtime.withFrameNanos { /* sync to frame boundary */ }
                gateOpen = true
            }
        }

        return if (gateOpen) COERCE_MAX else COERCE_MIN
    }


    fun Modifier.blockParentDragWhilePressed(enabled: Boolean): Modifier =
        if (!enabled) this
        else pointerInput(Unit) {
            val touchSlop = viewConfiguration.touchSlop
            awaitPointerEventScope {
                while (true) {
                    val down = awaitFirstDown(
                        pass = PointerEventPass.Initial,      // observe before children
                        requireUnconsumed = false
                    )
                    var dx = 0f
                    var dy = 0f
                    var verticalDrag = false
                    val pointerId = down.id

                    while (down.pressed) {
                        val event = awaitPointerEvent(pass = PointerEventPass.Initial)
                        val change = event.changes.firstOrNull { it.id == pointerId } ?: event.changes.first()
                        val delta = change.positionChange()

                        dx += abs(delta.x)
                        dy += abs(delta.y)

                        // Once user commits to vertical motion, stop consuming so parent can handle the drawer
                        if (!verticalDrag && dy > touchSlop && dy > dx) {
                            verticalDrag = true
                        }

                        if (!verticalDrag) {
                            // Tap/press or horizontal movement stays handled by the child
                            change.consume()
                        }

                        if (change.changedToUpIgnoreConsumed()) break
                    }
                }
            }
        }

