/**
 * @param scope - coroutine scope
 * @param dispatcher - dispatcher for coroutine
 * @property drawerEvent - reference to TopDrawerState class
 * @property viewModelFactory - to provide the Top drawer view model
 * @property activityLauncher - to launch activity specified by the class
 *    type
 * @property bottomBarInteractor - interface to interact with bottombar
 * @property context - context
 */
class RccdTopDrawerInflater @Inject constructor(
    private val drawerEvent: RccdTopDrawerState,
    private val viewModelFactory: ViewModelProvider.Factory,
    private val activityLauncher: IActivityLauncher,
    private val scope: ISequentialCoroutine,
    @CoroutineDispatchers(Dispatcher.DEFAULT) dispatcher: CoroutineDispatcher,
    private val bottomBarInteractor: RccdBottomBarInteractor,
    private val topDrawerInteractor: IRccdTopDrawerInteractor,
    @ApplicationContext private val context: Context,
    private val launcherInteractor: ILauncherInteractor,
    private val rccdTopDrawerViewModel: RccdTopDrawerViewModel,
    private val screenSaverViewModel: ScreenSaverViewModel,
    private val topBarInteractor: RccdTopBarInteractor
) : ThemedComposeInflater() {

    private val isDrawerOpening = MutableStateFlow(value = true)
    private val isDrawerFullClosed = MutableStateFlow(value = false)
    private val isDrawerFullOpened = MutableStateFlow(value = true)

    init {
        drawerEvent.gestureEvent.collectDragEvent(
            coroutineScope = scope,
            dispatcher = dispatcher
        ) {
            if (this is DragState.DRAGGING) {
                // if more than 1/4th of the drawer is not visible, we consider it is getting closed
                // and hide UI which is on lower side of drawer so that topbar is visible properly
                if (this.actualValue * -1 > context.dimension(R.integer.rccd_top_drawer_y) * 1 / 4) {
                    // drawer is  getting closed
                    isDrawerOpening.emit(false)
                } else {
                    // drawer is getting opened
                    isDrawerOpening.emit(true)
                }
                if ((this.actualValue * -1).toInt() == context.dimension(R.integer.rccd_top_drawer_y)) {
                    // drawer is fully closed
                    topDrawerInteractor.setDrawerHiddenState(true)
                    topDrawerInteractor.setHideDrawerFlag(true)
                    isDrawerFullClosed.emit(true)
                } else {
                    // drawer is not full closed
                    isDrawerFullClosed.emit(false)
                }

                if(isDrawerFullClosed.value){
                    launcherInteractor.setNavigationStatus(false)
                }

                if ((this.actualValue * -1).toInt() == 0) {
                    // drawer is fully opened
                    isDrawerFullOpened.emit(true)
                    topDrawerInteractor.setDrawerHiddenState(false)
                    topDrawerInteractor.setHideDrawerFlag(false)
                    bottomBarInteractor.updateBottomBarBackground(true)
                    launcherInteractor.setIsTempPageScreen(false)
                    launcherInteractor.setIsDistributionPageScreen(false)
                    launcherInteractor.setShouldOpenDistributionScreen(false)
                    launcherInteractor.setShouldOpenTempScreen(false)
                    launcherInteractor.setShouldOpenSeatsScreen(false)
                    if(!launcherInteractor.isNavigating.value){
                        launcherInteractor.setShouldOpenHomeListScreen(true)
                        launcherInteractor.setIsSeatsPageScreen(false)
                        launcherInteractor.setAirFlowClickState(true)
                    }
                } else {
                    isDrawerFullOpened.emit(false)
                    bottomBarInteractor.updateBottomBarBackground(true)
                }
            }
        }
    }

    @Composable
    override fun Content(view: IWindowComposeView) {
        val shouldOpenDrawer by topDrawerInteractor.shouldCloseDrawer.collectAsState()
        if (!(rccdTopDrawerViewModel.isValetModeActivated || rccdTopDrawerViewModel.rearConvenienceLockState) && !screenSaverViewModel.rccdScreenSaverVisibility && !screenSaverViewModel.rccdOffScreenVisibility) {
            TopDrawerScreen()

            val shouldHideDrawer = topDrawerInteractor.shouldHideDrawer.collectAsState()
            if (shouldHideDrawer.value && isDrawerFullOpened.collectAsState().value) {
                drawerEvent.toggleDrawer()
            }
            LaunchedEffect(shouldOpenDrawer) {
                if (shouldOpenDrawer) {
                    JeaLogger.debug("closing drawer after 30 Secs", "RCCDTopDrawerInflater")

                    drawerEvent.openDrawer()
                    topDrawerInteractor.setCloseDrawer(false)
                }
            }
        }
    }

    @Composable
    private fun TopDrawerScreen() {
        TopDrawerGroup()
    }

    @Composable
    private fun TopDrawerGroup() {
        val rccdTopDrawerViewModel: RccdTopDrawerViewModel = viewModelFactory.get()
        val efficientAutoMode by rccdTopDrawerViewModel.hvacEfficientAutoMode.collectAsState()

        Box(modifier = Modifier.fillMaxSize()) {
            Box(
                modifier = Modifier.fillMaxSize()
            ) {
                // Set Drawer Background
                if (isDrawerFullClosed.collectAsState().value) {
                    ImageComponent(
                        id = JeaCommonTheme.configProvider.jeaFccdTopHeaderDrawerBgImage,
                        contentDescription = stringResource(id = R.string.jea_content_description_fccd_drawer_bg),
                        contentScale = ContentScale.FillBounds,
                        modifier = Modifier
                            .wrapContentSize()
                            .align(Alignment.BottomStart)
                    )
                } else {
                    ImageComponent(
                        id = JeaCommonTheme.configProvider.jeaFccdDrawerBgImage,
                        contentDescription = stringResource(id = R.string.jea_content_description_fccd_drawer_bg),
                        contentScale = ContentScale.FillBounds,
                        modifier = Modifier.fillMaxSize()
                    )
                }
                // Set Drawer Shadow
                if (isDrawerFullOpened.collectAsState().value || isDrawerFullClosed.collectAsState().value) {
                    Box(
                        modifier = Modifier
                            .height(dimensionResource(R.dimen.fccd_top_drawer_height))
                            .width(dimensionResource(R.dimen.fccd_top_drawer_width))
                    ) {
                        ImageComponent(
                            id = JeaCommonTheme.configProvider.jeaFccdDrawerBgShadowImage,
                            contentDescription = stringResource(id = R.string.jea_content_description_fccd_drawer_bg),
                            modifier = Modifier.fillMaxSize(),
                        )
                    }
                }

                Column(
                    horizontalAlignment = Alignment.CenterHorizontally,
                    modifier = Modifier
                        .offset(y = LocalContext.current.dimension(R.integer.rccd_top_drawer_seats_climate_padding).dp)
                        .width(LocalContext.current.dimension(R.integer.rccd_top_drawer_width).dp)
                ) {
                    if (isDrawerOpening.collectAsState().value) {
                        JLRTheme {
                            DrawerContent(rccdTopDrawerViewModel, efficientAutoMode)
                        }
                    }
                }
                // Set Drawer dragging markers
                Box(
                    Modifier
                        .align(Alignment.BottomCenter)
                        .offset(y = dimensionResource(R.dimen.fccd_drawer_marker_y_offset))

                ) {
                    Image(
                        painter = painterResource(JeaCommonTheme.configProvider.jeaFccdDrawerBgBottomMarkingImage),
                        contentDescription = stringResource(R.string.jea_content_description_fccd_drawer),
                    )
                }

                // Enable Shadow from Top Bar or TopDrawer
                if (!isDrawerFullClosed.collectAsState().value && !isDrawerFullOpened.collectAsState().value) {
                    topBarInteractor.setRCCDDrawerOpenState(false)
                } else {
                    topBarInteractor.setRCCDDrawerOpenState(true)
                }

                Box(
                    modifier = Modifier
                        .width(LocalContext.current.dimension(R.integer.rccd_top_drawer_handle_width).dp)
                        .height(LocalContext.current.dimension(R.integer.rccd_top_drawer_handle_height).dp)
                        .offset(
                            x = LocalContext.current.dimension(R.integer.rccd_top_drawer_handle_x).dp,
                            y = LocalContext.current.dimension(R.integer.rccd_top_drawer_handle_y).dp
                        )
                        .detectGestureEvent(drawerEvent.gestureEvent)
                )
            }
        }
    }

    /* Composes the climate components(left climate control, right Climate
    * control), recirculation and Sync buttons
    *
    * @param rccdTopDrawerViewModel
    */
    @Composable
    fun DrawerContent(rccdTopDrawerViewModel: RccdTopDrawerViewModel, efficientAutoMode: EfficientAutoMode?) {
        val rccdHomeScreenLockType = rccdTopDrawerViewModel.rccdHomeScreenLockType.collectAsState()
        val rccdHomeScreenLockTimerStatus = rccdTopDrawerViewModel.rccdHomeScreenLockTimerStatus.collectAsState()
        val isTemperatureCelsius = rccdTopDrawerViewModel.temperatureStateHandler.isTemperatureCelcius.collectAsState().value
        val climateRearRowPowerState = rccdTopDrawerViewModel.climateRearRowPowerState.collectAsState().value

        var showContent by remember { mutableStateOf(true) }
        var temperatureValue by remember { mutableFloatStateOf(0f) }
        var showBubble by remember { mutableStateOf(false) }
        val targetAlpha = if (showContent) COERCE_MAX else COERCE_MIN
        val animatedAlpha by animateFloatAsState(targetValue = targetAlpha, animationSpec = tween(TIMEOUT_400_MIL_SECOND))
        var isLeftSliderOpen by remember { mutableStateOf(false) }
        var isRightSliderOpen by remember { mutableStateOf(false) }
        var activeDragSide by remember { mutableStateOf<String?>(null) }

        LaunchedEffect(key1 = rccdHomeScreenLockTimerStatus.value) {
            if (rccdHomeScreenLockTimerStatus.value) {
                Log.d("RCCD", "before 4 seconds")
                delay(4000)
                rccdTopDrawerViewModel.setRccdTempClimateLock(RccdLockType.RCCD_NO_LOCK)
                Log.d("RCCD", "after 4 seconds")
            }
        }

        Box {
            Row(
                modifier = Modifier
                    .height(LocalContext.current.dimension(R.integer.rccd_top_drawer_items_row_height).dp)
                    .width(LocalContext.current.dimension(R.integer.rccd_top_drawer_items_row_width).dp)
            ) {
                LeftColumnGroup(rccdTopDrawerViewModel = rccdTopDrawerViewModel,
                    showContent = showContent,
                    showBubble = showBubble,
                    onJeaACTempDragStart = {
                        activeDragSide = "left"
                        showContent = false
                        isLeftSliderOpen = true
                        showBubble = true
                        temperatureValue = rccdTopDrawerViewModel.rearRowLeftTemperature.value
                        JeaLogger.info("TempProgressVal= $temperatureValue", tag = "FCCDDragVal")
                    },
                    onJeaACTempDragEnd = {
                        scope.launch {
                            showContent = true
                            delay((BUBBLE_ANIMATION_DURATION + FADE_IN_ANIMATION_DURATION).toLong())
                            isLeftSliderOpen = false
                            showBubble = false
                            activeDragSide = null
                        }

                    },
                    onTemperatureChange = { temperatureValue = it },
                    isTemperatureCelsius = isTemperatureCelsius,
                    tempValue = temperatureValue,
                    isLeftOpen = isLeftSliderOpen,
                    activeDragSide = activeDragSide,
                    climateRearRowPowerState)
                MiddleColumnGroup(rccdTopDrawerViewModel = rccdTopDrawerViewModel, efficientAutoMode = efficientAutoMode, showContent = showContent, showBubble = showBubble, tempValue = temperatureValue, activeDragSide = activeDragSide, climateRearRowPowerState)
                RightColumnGroup(rccdTopDrawerViewModel = rccdTopDrawerViewModel, isTemperatureCelsius, climateRearRowPowerState, showContent = showContent, showBubble = showBubble,
                    onJeaACTempDragStart = {
                        scope.launch {
                            activeDragSide = "right"
                            showContent = false
                            isRightSliderOpen = true
                            delay((FADE_IN_ANIMATION_DURATION).toLong())
                            showBubble = true
                            temperatureValue = rccdTopDrawerViewModel.rearRowRightTemperature.value
                        }
                                           },
                    onJeaACTempDragEnd = {
                        scope.launch {
                            showContent = true
                            delay((BUBBLE_ANIMATION_DURATION + FADE_IN_ANIMATION_DURATION).toLong())
                            isRightSliderOpen = false
                            showBubble = false
                            activeDragSide = null
                        }
                    },
                    tempValue = temperatureValue,
                    onTemperatureChange = { temperatureValue = it },
                    isRightOpen = isRightSliderOpen,
                    activeDragSide = activeDragSide,)
            }

            if (rccdHomeScreenLockType.value != RccdLockType.RCCD_NO_LOCK)
                Box(
                    modifier = Modifier
                        .fillMaxSize()
                        .background(Color.Transparent),
                ) {
                    RccdLockView(rccdHomeScreenLockType.value, dimensionResource(id = R.dimen.rccd_no_lock_top_padding))
                }
        }
    }

