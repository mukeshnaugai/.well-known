    @Composable
    fun RightColumnGroup(
        fccdTopDrawerViewModel: FccdTopDrawerViewModel, showContent: Boolean, showBubble: Boolean,
        onJeaACTempDragStart: () -> Unit,
        onJeaACTempDragEnd: () -> Unit,
        onTemperatureChange: (Float) -> Unit,
        tempValue: Float,
        isRightOpen: Boolean,
        activeDragSide: String?
    ) {
        val rightClimateCurrentValue =
            when (context.isLHD()) {
                false -> fccdTopDrawerViewModel.frontRowLeftTemperature.collectAsState()
                true -> fccdTopDrawerViewModel.frontRowRightTemperature.collectAsState()
            }
        val decrementPassengerButtonState = remember { mutableStateOf(com.jlr.ui.State(enabled = true)) }
        val incrementPassengerButtonState = remember { mutableStateOf(com.jlr.ui.State(enabled = true)) }
        var toastJob by remember { mutableStateOf<Job?>(null) }
        val coroutineScope = rememberCoroutineScope()
        val bubbleHeight = 50.dp
        val bubbleWidth = 60.dp
        val bubbleTargetHeight = 360.dp
        val isTemperatureCelsius: Boolean = fccdTopDrawerViewModel.temperatureStateHandler.isTemperatureCelcius.collectAsState().value
        val climateFrontRowPowerButtonState = fccdTopDrawerViewModel.climateFrontRowPowerButtonState.collectAsState().value


        LaunchedEffect(key1 = rightClimateCurrentValue) {
            JeaLogger.debug("LeftColumnGroup called rightClimateCurrentValue :$rightClimateCurrentValue ")
        }

        Column(
            modifier = Modifier
                .height(dimensionResource(R.dimen.fccd_drawer_right_column_height))
                .width(dimensionResource(R.dimen.fccd_drawer_right_column_width)),
            verticalArrangement = Arrangement.SpaceBetween,
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            var decrementButtonStatePassenger = if (rightClimateCurrentValue.value <= TemperatureStateHandler.TEMPERATURE_MIN_VALUE_PASSENGER) {
                com.jlr.ui.State(enabled = false)
            } else {
                com.jlr.ui.State(enabled = true)
            }
            var incrementButtonStatePassenger = if (rightClimateCurrentValue.value >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER) {
                com.jlr.ui.State(enabled = false)
            } else {
                com.jlr.ui.State(enabled = true)
            }

            if (showBubble) {

                if (isRightOpen) {
                    var expanded by remember { mutableStateOf(false) }
                    var visible by remember { mutableStateOf(true) }

                    // Animate height from bubble to slider and back
                    val animatedHeight by animateDpAsState(
                        targetValue = if (expanded) bubbleTargetHeight else bubbleHeight,
                        animationSpec = tween(durationMillis = BUBBLE_ANIMATION_DURATION, easing = FastOutSlowInEasing)
                    )

                    // Animate alpha for fade in/out
                    val animatedAlpha by animateFloatAsState(
                        targetValue = if (visible) COERCE_MAX else COERCE_MIN,
                        animationSpec = tween(durationMillis = 400)
                    )

                    val bubbleWidth = bubbleWidth

                    Box(
                        modifier = Modifier.fillMaxSize(),
                        contentAlignment = Alignment.Center
                    ) {
                        Box(
                            modifier = Modifier
                                .width(bubbleWidth)
                                .height(animatedHeight)
                                .offset(y = dimensionResource(R.dimen.fccd_slider_yoffset))
                                .alpha(animatedAlpha)
                                .clip(RoundedCornerShape(dimensionResource(R.dimen.fccd_slider_corner_radius)))
                        ) {
                            Image(
                                painter = painterResource(id = R.drawable.jea_climate_slider),
                                contentDescription = stringResource(R.string.jea_content_description_fccd_drawer),
                                contentScale = ContentScale.FillBounds,
                                modifier = Modifier.fillMaxSize()
                            )
                        }
                    }

                    // Start expansion when bubble appears
                    LaunchedEffect(Unit) {
                        expanded = true
                    }

                    // Reverse when drag ends
                    LaunchedEffect(showContent) {
                        if (showContent) {
                            expanded = false // Shrink back
                            delay(600)       // Wait for shrink animation
                            visible = false  // Fade out
                        }
                    }
                }
            }
            Box {
                val dragAlpha = calculateDragAlpha(showContent, activeDragSide, isLeftColumn = false, isRightColumn = true)
                val dragOffset by animateDpAsState(
                    if (showContent) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset) else dimensionResource(R.dimen.fccd_drawer_animation_target_offset), tween(TIMEOUT_400_MIL_SECOND)
                )
                Box(
                    modifier = Modifier
                        .alpha(dragAlpha)
                        .offset(y = dragOffset)
                        .blockParentDragWhilePressed(enabled = showBubble && isRightOpen)
                ) {
                    val isColumnReversed = !context.isLHD()
                    JeaAcTemp(
                        jeaAcTempsConfig = JeaTheme.configProvider.jeaAcTempsConfig.copy(
                            minValue = if (isTemperatureCelsius) TEMPERATURE_MIN_VALUE else TEMPERATURE_MIN_VALUE_FAHRENHEIT,
                            maxValue = if (isTemperatureCelsius) TemperatureStateHandler.Companion.TEMPERATURE_MAX_VALUE else TEMPERATURE_MAX_VALUE_FAHRENHEIT,
                            minValueTextString = stringResource(if (isTemperatureCelsius) R.string.jea_climate_option_temp_low_celcius_passenger else R.string.jea_climate_option_temp_low_fahrenheit_passenger),
                            maxValueTextString = stringResource(if (isTemperatureCelsius) R.string.jea_climate_option_temp_hi_celcius_passenger else R.string.jea_climate_option_temp_hi_fahrenheit_passenger),
                            stepValue = TemperatureStateHandler.TEMPERATURE_STEP_VALUE,
                            offTextString = if (climateFrontRowPowerButtonState) null else stringResource(R.string.jea_climate_option_temp_off),
                        ),
                        jeaAcTempState = JeaAcTempState(
                            shouldShowFloat = isTemperatureCelsius,
                            isEnable = !lowPowerModeEnabled,
                            decrementButtonState = decrementButtonStatePassenger,
                            incrementButtonState = incrementButtonStatePassenger,
                            onDecrementBtnClick = { value: Float, valueType: ValueType ->
                                JeaLogger.info(message = "will decrement front right temp, current temp is ${rightClimateCurrentValue.value}", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                fccdTopDrawerViewModel.isDrawerSlidable = false
                                fccdTopDrawerViewModel.isDriverTemperatureSelected = false
                                val nextValue = rightClimateCurrentValue.value - TemperatureStateHandler.TEMPERATURE_STEP_VALUE
                                if (nextValue >= TEMPERATURE_MIN_VALUE_PASSENGER) {
                                    if (!isColumnReversed) {
                                        fccdTopDrawerViewModel.setFrontRightSeatTemperature(nextValue)
                                    } else {
                                        fccdTopDrawerViewModel.setFrontLeftSeatTemperature(nextValue)
                                    }
                                }
                                fccdTopDrawerViewModel.isDrawerSlidable = true
                            },
                            buttonClick = {
                                fccdTopDrawerViewModel.isDrawerSlidable = false
                                if (!topDrawerInteractor.isDrawerHidden.value) {
                                    topDrawerInteractor.setHideDrawerFlag(true)
                                }
                                if (!launcherInteractor.isTempPageScreen.value) {
                                    launcherInteractor.setShouldOpenTempScreen(true)
                                }
                                fccdTopDrawerViewModel.isDrawerSlidable = true
                            },
                            onIncrementBtnClick = { value: Float, valueType: ValueType ->
                                fccdTopDrawerViewModel.isDrawerSlidable = false
                                fccdTopDrawerViewModel.isDriverTemperatureSelected = false
                                JeaLogger.info(message = "will increment front right temp, current temp is ${rightClimateCurrentValue.value}", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                val nextValue = rightClimateCurrentValue.value + TemperatureStateHandler.TEMPERATURE_STEP_VALUE
                                if (nextValue <= TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER) {
                                    if (!isColumnReversed) {
                                        fccdTopDrawerViewModel.setFrontRightSeatTemperature(nextValue)
                                    } else {
                                        fccdTopDrawerViewModel.setFrontLeftSeatTemperature(nextValue)
                                    }
                                }
                                fccdTopDrawerViewModel.isDrawerSlidable = true
                            },
                            isDetoxModeActive = isDetoxModeEnabled,
                            darkMode = false,
                            valueBottomTextBoxState = if (fccdTopDrawerViewModel.isTemperatureCelcius == true) rightClimateCurrentValue.value
                            else {
                                val currentCelsius = rightClimateCurrentValue.value
                                when {
                                    currentCelsius <= minTempInCelsius -> minTempInFahrenheit.toFloat()
                                    currentCelsius >= maxTempInCelsius -> maxTempInFahrenheit.toFloat()
                                    else -> {
                                        celsiusToFahrenheit(currentCelsius)
                                    }
                                }
                            },
                            dragEventAllowed = true,
                            onDragStart =
                                {
                                    fccdTopDrawerViewModel.isDriverTemperatureSelected = false
                                    fccdTopDrawerViewModel.isDrawerSlidable = false
                                    onJeaACTempDragStart()
                                },

                            onDragEnd = {
                                val setTempVal = when {
                                    tempValue >= TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER -> TemperatureStateHandler.TEMPERATURE_MAX_VALUE_PASSENGER
                                    tempValue <= TEMPERATURE_MIN_VALUE_PASSENGER -> TEMPERATURE_MIN_VALUE_PASSENGER
                                    else -> tempValue
                                }
                                if (!isColumnReversed) {
                                    fccdTopDrawerViewModel.setFrontRightSeatTemperature(setTempVal)
                                } else {
                                    fccdTopDrawerViewModel.setFrontLeftSeatTemperature(setTempVal)
                                }
                                onJeaACTempDragEnd()
                                JeaLogger.info("TempProgressVal= $tempValue", tag = "FCCDDragVal")
                                fccdTopDrawerViewModel.isDrawerSlidable = true

                            },

                            onDragInProgress = { progressVal ->
                                fccdTopDrawerViewModel.isDrawerSlidable = false
                                onTemperatureChange(rightClimateCurrentValue.value + (progressVal.toFloat() / 2))
                                JeaLogger.info("DragVal= $progressVal", tag = "FCCDDragVal")
                            }
                        )
                    )
                }

            }

            Spacer(modifier = Modifier.height(dimensionResource(R.dimen.fccd_top_drawer_gap_between_components)))
            if (!isDetoxModeEnabled) {
                Box {
                    val dragAlpha = calculateDragAlpha(showContent, activeDragSide, isLeftColumn = false, isRightColumn = true)
                    val dragOffset by animateDpAsState(
                        if (showContent) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset) else dimensionResource(R.dimen.fccd_drawer_animation_target_offset), tween(TIMEOUT_400_MIL_SECOND)
                    )
                    Box(
                        modifier = Modifier
                            .alpha(dragAlpha)
                            .offset(y = dragOffset)
                            .blockParentDragWhilePressed(false)
                    ) {
                        JeaCircularButton(
                            JeaCircularButtonState(
                                iconResId = if (fccdTopDrawerViewModel.gloveboxState?.state == GLOVEBOX_OFF) R.drawable.glovebox_locked else R.drawable.jea_glovebox,
                                mode = com.jlr.ui.State(enabled = !fccdTopDrawerViewModel.isValetModeActivated),
                                showBg = false,
                                onClick = {
                                    toastJob?.cancel()
                                    toastJob = null
                                    if (fccdTopDrawerViewModel.gloveboxState?.state == GLOVEBOX_OFF) {
                                        if (fccdTopDrawerViewModel.gearStatus?.isParkingGear == true) {
                                            fccdTopDrawerViewModel.updateGloveBoxStatus()
                                            JeaLogger.info(message = "Vehicle in Parking mode. Start unlocking glovebox", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                        } else {
                                            JeaLogger.info(message = "Vehicle not in Parking mode. Show toast", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                            gloveBoxPopup.showPopUp()
                                            toastJob = coroutineScope.launch {
                                                delay(GLOVEBOX_TOAST_TIMEOUT)
                                                gloveBoxPopup.dismiss()
                                                toastJob = null
                                            }
                                            if (fccdTopDrawerViewModel.gloveBoxDoubleClick) {
                                                JeaLogger.info(message = "Vehicle not in Parking mode. Starting to unlock glovebox after double click", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                                toastJob?.cancel()
                                                toastJob = null
                                                resetToast(fccdTopDrawerViewModel)
                                                fccdTopDrawerViewModel.gloveBoxDoubleClick = false
                                                fccdTopDrawerViewModel.updateGloveBoxStatus()
                                            } else {
                                                JeaLogger.info(message = "Vehicle not in Parking mode. Double click not done", module = "systembar", feature = "fccddrawer", fileName = "TopDrawerInflater")
                                                fccdTopDrawerViewModel.gloveBoxDoubleClick = true
                                            }
                                        }
                                    }
                                },
                                interactionMode = CircularBtnInteractionMode.DEFERRED_CLICK

                            ),
                            jeaCircularButtonConfig = JeaTheme.configProvider.jeaCircularButtonConfig.copy(
                                jeaCircularButtonStyle = JeaCircularButtonStyle.LIGHT,
                                padding = Padding(
                                    top = dimensionResource(R.dimen.jea_glovebox_top_padding),
                                    end = dimensionResource(R.dimen.jea_glovebox_right_padding),
                                    bottom = dimensionResource(R.dimen.jea_glovebox_bottom_padding),
                                    start = dimensionResource(R.dimen.jea_glovebox_left_padding)
                                )
                            )
                        )
                    }

                }

                Spacer(modifier = Modifier.height(dimensionResource(R.dimen.fccd_top_drawer_gap_between_components)))
                Box {
                    val passengerSeatTemperature = if (context.isLHD()) fccdTopDrawerViewModel.passengerSeatTemperature else fccdTopDrawerViewModel.driverSeatTemperature
                    val dragAlpha = calculateDragAlpha(showContent, activeDragSide, isLeftColumn = false, isRightColumn = true)
                    val dragOffset by animateDpAsState(
                        if (showContent) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset) else dimensionResource(R.dimen.fccd_drawer_animation_target_offset), tween(TIMEOUT_400_MIL_SECOND)
                    )
                    Box(
                        modifier = Modifier
                            .alpha(dragAlpha)
                            .offset(y = dragOffset)
                            .blockParentDragWhilePressed(false)
                    ) {
                        JeaSeatTemp(
                            JeaTheme.configProvider.jeaSeatTempConfig.copy(
                                minValue = fccdTopDrawerViewModel.minIntensityListValue,
                                maxValue = TEMPERATURE_MAX_VALUE
                            ),
                            JeaSeatTempState(
                                isEnable = !fccdTopDrawerViewModel.isValetModeActivated && !fccdTopDrawerViewModel.isModeTransport,
                                decrementButtonState = if (fccdTopDrawerViewModel.isModeTransport) com.jlr.ui.State(enabled = false) else decrementPassengerButtonState.value,
                                incrementButtonState = if (fccdTopDrawerViewModel.isModeTransport) com.jlr.ui.State(enabled = false) else incrementPassengerButtonState.value,
                                onDecrementBtnClick = { value: Float, valueType: ValueType ->
                                    if (!fccdTopDrawerViewModel.isValetModeActivated && !fccdTopDrawerViewModel.isModeTransport) {
                                        val latestCurrent = if (context.isLHD()) fccdTopDrawerViewModel.passengerSeatTemperature else fccdTopDrawerViewModel.driverSeatTemperature
                                        when (valueType) {
                                            ValueType.NUMBER,
                                            ValueType.NUMBER_WITH_MIN_MAX_TEXT
                                                -> {

                                                decrementPassengerButtonState.value = if (passengerSeatTemperature == fccdTopDrawerViewModel.minIntensityListValue) {
                                                    com.jlr.ui.State(enabled = false)
                                                } else {
                                                    com.jlr.ui.State(enabled = true)
                                                }
                                                incrementPassengerButtonState.value = if (passengerSeatTemperature == TEMPERATURE_MAX_VALUE) {
                                                    com.jlr.ui.State(enabled = false)
                                                } else {
                                                    com.jlr.ui.State(enabled = true)
                                                }

                                                val next = when {
                                                    // Special Case: If the seat is currently OFF, first down press goes to -3 (Max Cool)
                                                    latestCurrent == TEMPERATURE_OFF_VALUE -> {
                                                        if (fccdTopDrawerViewModel.climateCoolFitment) TEMPERATURE_MIN_VALUE_ZONE_DUAL
                                                        else TEMPERATURE_MIN_VALUE_ZONE_SINGLE
                                                    }
                                                    // Standard Case: Just decrement by 1 and let coerceIn handle the boundaries
                                                    else -> latestCurrent - TEMPERATURE_INCREMENT
                                                }.coerceIn(
                                                    if (fccdTopDrawerViewModel.climateCoolFitment) TEMPERATURE_MIN_VALUE_ZONE_DUAL else TEMPERATURE_MIN_VALUE_ZONE_SINGLE,
                                                    Companion.TEMPERATURE_MAX_VALUE
                                                )

                                                fccdTopDrawerViewModel.setSeatTemperature(
                                                    fccdTopDrawerViewModel.getSeatSelection(if (context.isLHD()) SEAT_POSITION_PASSENGER else SEAT_POSITION_DRIVER),
                                                    fccdTopDrawerViewModel.getSelectedSeatTemperature(next)
                                                )
                                            }

                                            ValueType.CUSTOM_TEXT -> {}
                                            ValueType.IMAGE -> {}
                                        }
                                    }
                                },
                                onIncrementBtnClick = { value: Float, valueType: ValueType ->
                                    if (!fccdTopDrawerViewModel.isValetModeActivated && !fccdTopDrawerViewModel.isModeTransport) {
                                        val latestCurrent = if (context.isLHD()) fccdTopDrawerViewModel.passengerSeatTemperature else fccdTopDrawerViewModel.driverSeatTemperature
                                        when (valueType) {
                                            ValueType.NUMBER,
                                            ValueType.NUMBER_WITH_MIN_MAX_TEXT
                                                -> {
                                                decrementPassengerButtonState.value = if (passengerSeatTemperature == fccdTopDrawerViewModel.minIntensityListValue) {
                                                    com.jlr.ui.State(enabled = false)
                                                } else {
                                                    com.jlr.ui.State(enabled = true)
                                                }
                                                incrementPassengerButtonState.value = if (passengerSeatTemperature == TEMPERATURE_MAX_VALUE) {
                                                    com.jlr.ui.State(enabled = false)
                                                } else {
                                                    com.jlr.ui.State(enabled = true)
                                                }

                                                val next = when {
                                                    // If OFF, jump to Max Heat (3)
                                                    latestCurrent == TEMPERATURE_OFF_VALUE -> SeatsTemperatureViewModel.TEMPERATURE_MAX_VALUE
                                                    // Otherwise, just step up
                                                    else -> latestCurrent + TEMPERATURE_INCREMENT
                                                }.coerceIn(
                                                    if (fccdTopDrawerViewModel.climateCoolFitment) TEMPERATURE_MIN_VALUE_ZONE_DUAL else TEMPERATURE_MIN_VALUE_ZONE_SINGLE,
                                                    SeatsTemperatureViewModel.TEMPERATURE_MAX_VALUE
                                                )

                                                fccdTopDrawerViewModel.setSeatTemperature(
                                                    fccdTopDrawerViewModel.getSeatSelection(if (context.isLHD()) SEAT_POSITION_PASSENGER else SEAT_POSITION_DRIVER),
                                                    fccdTopDrawerViewModel.getSelectedSeatTemperature(next)
                                                )
                                            }

                                            ValueType.CUSTOM_TEXT -> {}
                                            ValueType.IMAGE -> {}
                                        }
                                    }
                                },
                                darkMode = false,
                                inverse = (context.isLHD()),
                                valueBottomTextBoxState = if (context.isLHD()) fccdTopDrawerViewModel.passengerSeatTemperature else fccdTopDrawerViewModel.driverSeatTemperature,
                                valueBottomTextBoxPosition = 0,
                                buttonClick = {
                                    if (!fccdTopDrawerViewModel.isValetModeActivated && !fccdTopDrawerViewModel.isModeTransport) {
                                        val passengerSeatPosition = if (context.isLHD()) SEAT_POSITION_PASSENGER else SEAT_POSITION_DRIVER
                                        launcherInteractor.setShouldOpenSeatsSelectedScreen(passengerSeatPosition)
                                        JeaLogger.debug("setShouldOpenSeatsSelectedScreen, Passenger", "DrawerOpensSeats")
                                        if (!topDrawerInteractor.isDrawerHidden.value) {
                                            topDrawerInteractor.setHideDrawerFlag(true)
                                            JeaLogger.debug("setHideDrawerFlag, Passenger", "DrawerOpensSeats")
                                        }
                                        if (!launcherInteractor.isSeatsPageScreen.value) {
                                            launcherInteractor.setNavigationStatus(true)
                                            launcherInteractor.setShouldOpenHomeListScreen(false)
                                            launcherInteractor.setShouldOpenSeatsScreen(true)
                                            JeaLogger.debug("setShouldOpenSeatsScreen, Passenger", "DrawerOpensSeats")
                                        }
                                        if (!isDrawerFullClosed.value) {
                                            drawerEvent.closeDrawer()
                                        }
                                    }
                                },
                                isTextCircularButtonCLickEnabled = !fccdTopDrawerViewModel.isModeTransport,
                                isComponentClickEnabled = !fccdTopDrawerViewModel.isModeTransport
                            )
                        )
                    }

                }
            }
        }
    }

    @Composable
    fun calculateDragAlpha(
        showContent: Boolean,
        activeDragSide: String?,
        isLeftColumn: Boolean,
        isRightColumn: Boolean
    ): Float {
        if (activeDragSide == "left" && isRightColumn) return COERCE_MIN
        if (activeDragSide == "right" && isLeftColumn) return COERCE_MIN

        val revealReady = showContent && activeDragSide == null

        var gateOpen by remember { mutableStateOf(false) }

        LaunchedEffect(revealReady) {
            gateOpen = false

            if (revealReady) {
                androidx.compose.runtime.withFrameNanos { /* sync to frame boundary */ }
                gateOpen = true
            }
        }

        return if (gateOpen) COERCE_MAX else COERCE_MIN
    }

}

