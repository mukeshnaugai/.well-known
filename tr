fun Modifier.blockParentDragWhilePressed(enabled: Boolean): Modifier =
    if (!enabled) this
    else pointerInput(Unit) {
        val touchSlop = viewConfiguration.touchSlop
        awaitPointerEventScope {
            while (true) {
                val down = awaitFirstDown(
                    pass = PointerEventPass.Initial,      // observe before children
                    requireUnconsumed = false
                )
                var dx = 0f
                var dy = 0f
                var verticalDrag = false
                val pointerId = down.id

                while (down.pressed) {
                    val event = awaitPointerEvent(pass = PointerEventPass.Initial)
                    val change = event.changes.firstOrNull { it.id == pointerId } ?: event.changes.first()
                    val delta = change.positionChange()

                    dx += abs(delta.x)
                    dy += abs(delta.y)

                    // Once user commits to vertical motion, stop consuming so parent can handle the drawer
                    if (!verticalDrag && dy > touchSlop && dy > dx) {
                        verticalDrag = true
                    }

                    if (!verticalDrag) {
                        // Tap/press or horizontal movement stays handled by the child
                        change.consume()
                    }

                    if (change.changedToUpIgnoreConsumed()) break
                }
            }
        }
    }
