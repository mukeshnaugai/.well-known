                                JeaCircularButtonState(
                                    iconResId = R.drawable.jea_away_mode,
                                    showBg = false,
                                    mode = com.jlr.ui.State(selected = awayModeStatus, enabled = !lowPowerModeEnabled.value),
                                    onClick = {
                                        if (!awayModeStatus) {
                                            awayModePopup.showPopUp()
                                            fccdTopDrawerViewModel.awayModeStateHandler.setAwayMode(ClimateAway.CLIMATE_AWAY_MODE_ON)
                                            Log.d("AwayMode", awayModeStatus.toString())
                                        } else {
                                            fccdTopDrawerViewModel.awayModeStateHandler.setAwayMode(ClimateAway.CLIMATE_AWAY_MODE_OFF)
                                            Log.d("AwayMode", awayModeStatus.toString())
                                        }
                                    },
                                    interactionMode = CircularBtnInteractionMode.DEFERRED_CLICK
                                ),
                                jeaCircularButtonConfig
                            )
                        }
                    }
                }

                Spacer(modifier = Modifier.height(if (showAwayButton) dimensionResource(R.dimen.fccd_top_drawer_gap_between_components_away_mode) else dimensionResource(R.dimen.fccd_top_drawer_gap_between_components)))

                if (!isDetoxModeEnabled) {
                    Box {
                        val dragAlpha by animateFloatAsState(if (middleRevealGate) COERCE_MAX else COERCE_MIN, tween(TIMEOUT_400_MIL_SECOND))
                        val dragOffset by animateDpAsState(
                            if (middleRevealGate) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset)
                            else dimensionResource(R.dimen.fccd_drawer_animation_target_offset),
                            tween(TIMEOUT_400_MIL_SECOND)
                        )
                        Box(
                            modifier = Modifier
                                .alpha(dragAlpha)
                                .offset(y = dragOffset)
                                .blockParentDragWhilePressed(false)
                        ) {
                            JeaClimateBtn(
                                state = JeaClimateBtnState(
                                    variant = if (efficientAutoMode?.isEnabled == true) {
                                        JeaClimateBtnVariant.BtnWithIcon(
                                            iconRes = if (autoButtonState.value) R.drawable.jea_efficient_heating_selected else R.drawable.jea_efficient_heating_selectable,
                                            contentDescription = stringResource(id = R.string.jea_auto_text)
                                        )
                                    } else {
                                        JeaClimateBtnVariant.BtnWithIcon(
                                            iconRes = R.drawable.jea_auto,
                                            contentDescription = stringResource(id = R.string.jea_auto_text)
