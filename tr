                Spacer(modifier = Modifier.height(if (showAwayButton) dimensionResource(R.dimen.fccd_top_drawer_gap_between_components_away_mode) else dimensionResource(R.dimen.fccd_top_drawer_gap_between_components)))

                Box {
                    val dragAlpha by animateFloatAsState(if (middleRevealGate) COERCE_MAX else COERCE_MIN, tween(TIMEOUT_400_MIL_SECOND))
                    val dragOffset by animateDpAsState(
                        if (middleRevealGate) dimensionResource(R.dimen.fccd_drawer_animation_initial_offset)
                        else dimensionResource(R.dimen.fccd_drawer_animation_target_offset),
                        tween(TIMEOUT_400_MIL_SECOND)
                    )
                    Box(
                        modifier = Modifier
                            .alpha(dragAlpha)
                            .offset(y = dragOffset)
                            .blockParentDragWhilePressed(false)
                    ) {
                        JeaCircularButton(
                            JeaCircularButtonState(
                                iconResId = if (maxAcButtonState) R.drawable.jea_climate_max_ac_selected else R.drawable.jea_climate_max_ac,
                                mode = if (!lowPowerModeEnabled.value) {
                                    if (maxAcButtonState) com.jlr.ui.State(selected = true) else com.jlr.ui.State(enabled = true)
                                } else com.jlr.ui.State(enabled = false),
                                showBg = (!lowPowerModeEnabled.value && climateFrontRowPowerButtonState && maxAcButtonState ),
                                onClick = { fccdTopDrawerViewModel.toggleMaxACButtonState() },
