/**
 * View model for Top Drawer Inflater
 *
 * @property hvacAutoBlowerUseCase
 * @property hvacACUseCase
 * @property hvacMaxAcUseCase
 * @property hvacDefoggerUseCase
 * @property powerUseCase
 * @property hvacDualUseCase
 * @property hvacAutoUseCase
 * @property hvacTempUseCase
 * @property maxDefrostState
 * @property hvacDistributionStateUseCase
 * @property hvacClimatePreconditionUseCase
 * @property coroutineScope
 */
class RccdTopDrawerViewModel @Inject constructor(
    @CoroutineDispatchers(Dispatcher.MAIN) private val mainDispatcher: CoroutineDispatcher,
    @CoroutineDispatchers(DEFAULT) private val default: CoroutineDispatcher,
    @ApplicationContext val context: Context,
    private val hvacACUseCase: IHVACACState,
    private val hvacMaxAcUseCase: IHVACMaxACState,
    private val powerUseCase: IHVACPowerState,
    private val hvacDualUseCase: IHVACDualState,
    private val hvacAutoUseCase: IHVACAutoState,
    private val hvacTempUseCase: IHVACTempState,
    private val maxDefrostState: IHVACMaxDefrostState,
    private val hvacDistributionStateUseCase: IHVACDistributionState,
    private val efficientAutoState: IEfficientAutoState,
    private val coroutineScope: CoroutineScope,
    private val seatClimateInfo: ISeatClimateAvailability,
    private val climateIntensity: ISeatClimateIntensityLevel,
    private val familySettingUsecase: IFamilySettingUseCase,
    private val valetModeUseCase: IValetModeUseCase,
    private val tempState: ITemperatureUnitState,
    private val lowPowerModeUseCase: ILowPowerModeUseCase,
    val scope:CoroutineScope
    ) : ViewModel() {

    private val tempValue = -1
    val defrostButtonState: MutableStateFlow<Boolean> = MutableStateFlow(false)
    val rearRowLeftTemperature: MutableStateFlow<Float> =
        MutableStateFlow(TemperatureStateHandler.TEMPERATURE_DEFAULT_VALUE)
    val recirculationButtonState: MutableStateFlow<Boolean> = MutableStateFlow(false)
    val syncButtonState: MutableStateFlow<Boolean> = MutableStateFlow(false)
    val rearRowRightTemperature: MutableStateFlow<Float> =
        MutableStateFlow(TemperatureStateHandler.TEMPERATURE_DEFAULT_VALUE)
    val frontAutoButtonState: MutableStateFlow<Boolean> = MutableStateFlow(false)
    val maxAcButtonState: MutableStateFlow<Boolean> = MutableStateFlow(false)
    val acButtonState: MutableStateFlow<Boolean> = MutableStateFlow(false)
    var hvacEfficientAutoMode: MutableStateFlow<EfficientAutoMode?> = MutableStateFlow<EfficientAutoMode?>(null)
    var hvacRecircState by mutableStateOf<HvacRecircState?>(null)
    var frontDefoggerState by mutableStateOf<Boolean>(false)
    var rearDefoggerState by mutableStateOf<Boolean>(false)
    private var firstLaunch by mutableStateOf(true)
    var feedbackMessage by mutableStateOf(false)
    private var lastInteractionTime by mutableStateOf(0L)
    var climateCoolFitment by mutableStateOf(false)
    var rearLeftSeatTemperatures by mutableStateOf<Float>(0f)
    var rearRightSeatTemperatures by mutableStateOf<Float>(0f)
    var decrementPassengerButtonStateDisabled by  mutableStateOf(true)
    var incrementPassengerButtonStateDisabled by mutableStateOf(true)
    var decrementDriverButtonStateDisabled by  mutableStateOf(true)
    var incrementDriverButtonStateDisabled by mutableStateOf(true)
    var minIntensityListValue by mutableStateOf<Float>(TEMPERATURE_MIN_VALUE_ZONE_DUAL)
    var gearStatus by mutableStateOf<GearSelection?>(null)
    var gloveboxState by mutableStateOf<GloveBoxState?>(null)
    var showGloveBoxToast by mutableStateOf(false)
    var gloveBoxDoubleClick by mutableStateOf(false)
    var rearConvenienceLockState by mutableStateOf(false)
    val rccdHomeScreenLockTimerStatus: MutableStateFlow<Boolean> = MutableStateFlow(false)
    val rccdHomeScreenLockType: MutableStateFlow<RccdTopDrawerInflater.RccdLockType> = MutableStateFlow(RccdTopDrawerInflater.RccdLockType.RCCD_NO_LOCK)
    val rearLeftAcDistributionState: MutableStateFlow<HvacDistributionState> = MutableStateFlow(HvacDistributionState(FACE))
    private var valetModeState by mutableStateOf<ValetModeState?>(null)
    var isValetModeActivated by mutableStateOf(false)
    var valetModeAvailability by mutableStateOf(false)
    var lowPowerModeEnabled by mutableStateOf(false)
    val climateRearRowPowerState: MutableStateFlow<Boolean> = MutableStateFlow(true)
    var isDrawerSlidable by mutableStateOf(true)
    var isDriverTemperatureSelected by mutableStateOf(true)
    var isTemperatureCelcius by mutableStateOf<Boolean?>(null)
    var hvacSyncState by mutableStateOf<HvacSyncState?>(null)

    /**
     * @property temperatureStateHandler Contains State and business logic
     *    integration for Temperature screen
     */
    val temperatureStateHandler: TemperatureStateHandler = TemperatureStateHandler(
        hvacACUseCase = hvacACUseCase,
        hvacMaxAcUseCase = hvacMaxAcUseCase,
        coroutineScope = viewModelScope,
        hvacPowerState = powerUseCase,
        hvacTempUseCase = hvacTempUseCase,
        tempState = tempState,
        lowPowerModeUseCase = lowPowerModeUseCase,
        context = context
    )

    val distributionStateHandler: DistributionStateHandler = DistributionStateHandler(
        coroutineScope = viewModelScope,
        hvacDistributionUseCase = hvacDistributionStateUseCase,
        lowPowerModeUseCase = lowPowerModeUseCase
    )

    private fun collectLPMState() {
        JeaLogger.debug("collect LPM State ${this@RccdTopDrawerViewModel.hashCode()}")
        lowPowerModeUseCase.lowPowerModeState.collect(
            coroutineScope = scope, dispatcher = default
        ) {
            withContext(mainDispatcher) { lowPowerModeEnabled = this@collect.isLPMEnable }
        }
    }

    init {
        collectTemperatureUnitType()
        initRearLeftTemp()
        initMaxDefrostState()
        initSyncState()
        initRearRightTemp()
        initFrontAutoState()
        initHvacEfficientAuto()
        infoCCFState()
        initRearLockState()
        initAcDistribution()
        selectedSeatTemperatureIntensityState()
        collectValetModeState()
        collectLPMState()
        collectRearPowerState()
        distributionFromId()
    }
    private fun distributionFromId() {
        distributionStateHandler.setDistributionFromId(DistributionSeat.SEAT_REAR.id)
    }

    private fun collectRearPowerState() {
        coroutineScope.launch {
            powerUseCase.rearPowerState.collect() {
                it?.let {
                    climateRearRowPowerState.emit(it.isRearOn)
                }
            }
        }
    }

    private fun collectValetModeState() {
        valetModeUseCase.valetModeState.collect(
            coroutineScope = viewModelScope,
            dispatcher = default
        ) {
            withContext(mainDispatcher) {
                valetModeState = this@collect
                valetModeAvailability = valetModeState?.isValetModeAvailable ?: false
                isValetModeActivated = valetModeState?.isValetModeActive ?: false
            }
        }
    }

    /** This method will sync seat temperature intensity state from backend */
    private fun selectedSeatTemperatureIntensityState() {
        climateIntensity.leftRearIntensity.collect(viewModelScope, default) {
                withContext(mainDispatcher) {
                    if (this@collect.state == tempValue) return@withContext
                    rearLeftSeatTemperatures = getSelectedSeatTemperatureIntensity(this@collect.state)
                    decrementDriverButtonStateDisabled = isMinTemp(rearLeftSeatTemperatures)
                    incrementDriverButtonStateDisabled = isMaxTemp(rearLeftSeatTemperatures)
                    logDebug("driver seat temperature value $rearLeftSeatTemperatures")
                }
            }

        climateIntensity.rightRearIntensity.collect(viewModelScope, default) {
                withContext(mainDispatcher) {
                    if (this@collect.state == tempValue) return@withContext
                    rearRightSeatTemperatures = getSelectedSeatTemperatureIntensity(this@collect.state)
                    decrementPassengerButtonStateDisabled = isMinTemp(rearRightSeatTemperatures)
                    incrementPassengerButtonStateDisabled = isMaxTemp(rearRightSeatTemperatures)
                    logDebug("passenger seat temperature value $rearRightSeatTemperatures")
                }
            }
    }

    private fun isMinTemp(temperatureIntensity: Float): Boolean {
        return temperatureIntensity == minIntensityListValue
    }

    private fun isMaxTemp(temperatureIntensity: Float): Boolean {
        return temperatureIntensity == TEMPERATURE_MAX_VALUE
    }

    /**
     * seat temperature intensity level state to temperature value switcher
     * mapping
     */
    private fun getSelectedSeatTemperatureIntensity(temperatureIntensity: Int): Float {
        return when (temperatureIntensity) {
            ClimateIntensity.SEAT_CLIMATE_INTENSITY_OFF -> 0f
            ClimateIntensity.SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_1 -> 1f
            ClimateIntensity.SEAT_CLIMATE_INTENSITY_COOL_LEVEL_1 -> -1f
            ClimateIntensity.SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_2 -> 2f
            ClimateIntensity.SEAT_CLIMATE_INTENSITY_COOL_LEVEL_2 -> -2f
            ClimateIntensity.SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_3 -> 3f
            ClimateIntensity.SEAT_CLIMATE_INTENSITY_COOL_LEVEL_3 -> -3f
            else -> 0f
        }
    }

    private fun initAcDistribution() {
        coroutineScope.launch {

            hvacDistributionStateUseCase.rearLeftDistributionState.collect {
                logDebug("collect change in rearConvenienceLockState ${it?.id}")
                it?.let {
                    rearLeftAcDistributionState.emit(it)
                }
            }
        }
    }

    private fun initRearLockState() {
        familySettingUsecase.rearLockState.collect(
            coroutineScope = viewModelScope,
            dispatcher = default
        ) {
            withContext(mainDispatcher) {
                rearConvenienceLockState = this@collect.isSelected
                logDebug("Rccd rearLockState: ${this@collect}")
                }
            }
        }

    /** This method will sync required CCF states info from backend */
    private fun infoCCFState() {
        viewModelScope.launch(default) {
            withContext(mainDispatcher) {
                climateCoolFitment = seatClimateInfo.getClimateInfoCCFRow1()?.isRow1CoolAvailable ?: false
                minIntensityListValue = if (climateCoolFitment) TEMPERATURE_MIN_VALUE_ZONE_DUAL else TEMPERATURE_MIN_VALUE_ZONE_SINGLE
                logDebug("climate cool fitment value $climateCoolFitment")
            }
        }
    }

    private fun initMaxDefrostState() {
        coroutineScope.launch {
            maxDefrostState.state.collect {
                logDebug("collect change in maxDefrostState ${it?.isMaxDefrostOn}")
                JeaLogger.info(message = "collect change in front left temp", module = "systembar", feature = "rccddrawer", fileName = "TopDrawerInflater")
                it?.let {
                    defrostButtonState.emit(it.isMaxDefrostOn)
                }
            }
        }
    }

    private fun initRearLeftTemp() {
        coroutineScope.launch {
            hvacTempUseCase.rearLeftTempState.collect {
                logDebug("collect change in front left temp")
                it?.let {
                    logDebug("RCCD : rearLeftTempState : ${it.temp}")
                    rearRowLeftTemperature.emit(it.temp)
                }
            }
        }
    }

    private fun initSyncState() {
        coroutineScope.launch {
            hvacDualUseCase.state.collect {
                if (it != null) {
                    hvacSyncState = it
                    syncButtonState.emit(it.isSyncOn)
                }
            }
        }
    }

    private fun initRearRightTemp() {
        coroutineScope.launch {
            hvacTempUseCase.rearRightTempState.collect {
                logDebug("collect change in front right temp")
                it?.let {
                    logDebug("RCCD : rearRightTempState : ${it.temp}")
                    rearRowRightTemperature.emit(it.temp)
                }
            }
        }
    }

    private fun initFrontAutoState() {
        coroutineScope.launch {
            hvacAutoUseCase.frontHvacAutoState.collect {
                it?.let {
                    frontAutoButtonState.emit(it.autoOn)
                }
            }
        }
    }

    fun setFaceVentSwitch() {
        distributionStateHandler.switchFaceVent()
    }

    fun setFootVentSwitch() {
        distributionStateHandler.switchFootVent()
    }

    /** toggle maxDefrost state */
    fun toggleMaxDefrost() {
        maxDefrostState.switchMaxDefrost()
    }

    /** @param value */
    fun setRearLeftSeatTemperature(value: Float) {
        temperatureStateHandler.setRearRowLeftTemperature(value, FCCD)
    }

    /** toggle sync button state */
    fun toggleSyncButtonState() {
        hvacDualUseCase.switchSync(hvacSyncState?.switch)
    }

    /** @param value */
    fun setRearRightSeatTemperature(value: Float) {
        temperatureStateHandler.setRearRowRightTemperature(value, FCCD)
    }


    /** toggle auto button state */
    fun toggleFrontAutoButtonState() {
        hvacAutoUseCase.switchFrontAuto()
    }

    /** TODO sets Glove box status */
    fun updateGloveBoxStatus() {
        // TODO  - logic should be replaced with state value from back end during BL integration
    }

    /** toggle max ac state */
    fun toggleMaxACButtonState() {
        hvacMaxAcUseCase.switchMaxAC()
    }

    /** toggle ac state */
    fun toggleACButtonState() {
        hvacACUseCase.switchAC()
    }

    private fun initHvacEfficientAuto() {
        coroutineScope.launch {
            efficientAutoState.efficientAutoMode.collect() {
                hvacEfficientAutoMode.value = it

                logDebug("EfficientAuto : ${hvacEfficientAutoMode.value?.isEnabled}")
            }
        }
    }

    fun setSeatTemperature(seatPosition: Int, intensityValue: Int) {
        climateIntensity.setClimateIntensity(seatPosition, intensityValue)
    }

    /** selected seat position and vehicle seat area id mapping */
    fun getSeatSelection(selectedSeatPosition: Int): Int {
        return when (selectedSeatPosition) {
            SeatPosition.SEAT_POSITION_DRIVER -> SeatSelection.SEAT_SELECTION_FIRST_ROW_LEFT
            SeatPosition.SEAT_POSITION_PASSENGER -> SeatSelection.SEAT_SELECTION_FIRST_ROW_RIGHT
            SeatPosition.SEAT_POSITION_REAR_LEFT -> SeatSelection.SEAT_SELECTION_SECOND_ROW_LEFT
            SeatPosition.SEAT_POSITION_REAR_RIGHT -> SeatSelection.SEAT_SELECTION_SECOND_ROW_RIGHT
            else -> 0
        }
    }

    /** seat temperature value switcher to intensity level state mapping */
    fun getSelectedSeatTemperature(temperatureIntensity: Float): Int {
        return when (temperatureIntensity) {
            0f -> ClimateIntensity.SEAT_CLIMATE_INTENSITY_OFF
            1f -> ClimateIntensity.SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_1
            -1f -> ClimateIntensity.SEAT_CLIMATE_INTENSITY_COOL_LEVEL_1
            2f -> ClimateIntensity.SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_2
            -2f -> ClimateIntensity.SEAT_CLIMATE_INTENSITY_COOL_LEVEL_2
            3f -> ClimateIntensity.SEAT_CLIMATE_INTENSITY_HEAT_LEVEL_3
            -3f -> ClimateIntensity.SEAT_CLIMATE_INTENSITY_COOL_LEVEL_3
            else -> ClimateIntensity.SEAT_CLIMATE_INTENSITY_OFF
        }
    }

    private fun onHeatedScreenChanged() {
        feedbackMessage = true
        viewModelScope.launch(default) {
            delay(4000)
            withContext(mainDispatcher) { feedbackMessage = false }
        }
    }

    private fun lastInteractionLessThanTenSeconds(): Boolean {
        val currentTime = System.currentTimeMillis()
        val timeDifference = currentTime - lastInteractionTime
        lastInteractionTime = currentTime
        return timeDifference <= TIME_OUT
    }

    fun setRccdTempClimateLock(rearTempLockType: RccdTopDrawerInflater.RccdLockType) {
        rccdHomeScreenLockType.value = rearTempLockType
        if (rccdHomeScreenLockType.value != RccdTopDrawerInflater.RccdLockType.RCCD_NO_LOCK)
            setRccdTempClimateLockTimer(true)
        else
            setRccdTempClimateLockTimer(false)
    }

    fun setRccdTempClimateLockTimer(rccdHomeScreenLockTimerValue: Boolean) {
        rccdHomeScreenLockTimerStatus.value = rccdHomeScreenLockTimerValue
    }

    private fun collectTemperatureUnitType() {
        tempState.temperatureUnitState.collect(
            coroutineScope = viewModelScope,
            dispatcher = default
        ) {
            withContext(mainDispatcher) {
                isTemperatureCelcius = this@collect.isCelsius
            }
        }
    }
    companion object {
        const val TIME_OUT = 10000
        const val TIMEOUT_600_MIL_SECOND = 600L
        const val TIMEOUT_400_MIL_SECOND = 400

        const val ANIMATION_TIMEOUT_300_MIL_SECOND = 300

    }
}
